<Window x:Class="HandwritingFontCreator.UI.ColorPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        Title="Color settings"
        Width="480" Height="340"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#252526">

    <Window.Resources>
        <SolidColorBrush x:Key="Bg"      Color="#252526"/>
        <SolidColorBrush x:Key="Surface" Color="#2D2D30"/>
        <SolidColorBrush x:Key="Border"  Color="#3F3F46"/>
        <SolidColorBrush x:Key="Text"    Color="#D4D4D4"/>
        <SolidColorBrush x:Key="SubText" Color="#858585"/>
        <SolidColorBrush x:Key="Accent"  Color="#569CD6"/>
        <SolidColorBrush x:Key="BtnBg"   Color="#3C3C3C"/>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource Text}"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="Foreground"      Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="4,2"/>
            <Setter Property="CaretBrush"      Value="{StaticResource Text}"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="FontFamily"      Value="Consolas"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Background"       Value="{StaticResource BtnBg}"/>
            <Setter Property="Foreground"       Value="{StaticResource Text}"/>
            <Setter Property="BorderBrush"      Value="{StaticResource Border}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,0"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{StaticResource Accent}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource Accent}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top: preview + OK/Cancel -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10" LastChildFill="False">
            <!-- Old/new color preview -->
            <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,12,0">
                <Border Name="OldColorSwatch" Width="48" Height="36" CornerRadius="3,0,0,3"
                        BorderBrush="{StaticResource Border}" BorderThickness="1,1,0,1"/>
                <Border Name="NewColorSwatch" Width="48" Height="36" CornerRadius="0,3,3,0"
                        BorderBrush="{StaticResource Border}" BorderThickness="1"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                <Button Name="OkBtn" Content="OK" Width="74" Height="30" Margin="0,0,6,0"
                        Click="OK_Click" Background="{StaticResource Accent}"/>
                <Button Name="CancelBtn" Content="Cancel" Width="74" Height="30"
                        Click="Cancel_Click"/>
            </StackPanel>
        </DockPanel>

        <!-- Middle: SV area | hue strip | inputs -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="20"/>
                <ColumnDefinition Width="12"/>
                <ColumnDefinition Width="148"/>
            </Grid.ColumnDefinitions>

            <!-- SV picker -->
            <Border Grid.Column="0" BorderBrush="{StaticResource Border}" BorderThickness="1">
                <Grid>
                    <skia:SKElement Name="SvCanvas" PaintSurface="SvCanvas_Paint" IsHitTestVisible="False"/>
                    <Canvas Name="SvInputCanvas" Background="Transparent"
                            MouseLeftButtonDown="SvInput_MouseDown"
                            MouseMove="SvInput_MouseMove"
                            MouseLeftButtonUp="SvInput_MouseUp"/>
                </Grid>
            </Border>

            <!-- Hue strip -->
            <Border Grid.Column="2" BorderBrush="{StaticResource Border}" BorderThickness="1">
                <Grid>
                    <skia:SKElement Name="HueCanvas" PaintSurface="HueCanvas_Paint" IsHitTestVisible="False"/>
                    <Canvas Name="HueInputCanvas" Background="Transparent"
                            MouseLeftButtonDown="HueInput_MouseDown"
                            MouseMove="HueInput_MouseMove"
                            MouseLeftButtonUp="HueInput_MouseUp"/>
                </Grid>
            </Border>

            <!-- Inputs panel -->
            <StackPanel Grid.Column="4" VerticalAlignment="Top">

                <!-- HSV group -->
                <TextBlock Text="HSV" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource SubText}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="H:" FontSize="11" Foreground="{StaticResource SubText}"/>
                    <TextBox Name="HInput" Grid.Column="1" Height="22" TextChanged="HsvInput_Changed"/>
                </Grid>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="S:" FontSize="11" Foreground="{StaticResource SubText}"/>
                    <TextBox Name="SInput" Grid.Column="1" Height="22" TextChanged="HsvInput_Changed"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="V:" FontSize="11" Foreground="{StaticResource SubText}"/>
                    <TextBox Name="VInput" Grid.Column="1" Height="22" TextChanged="HsvInput_Changed"/>
                </Grid>

                <!-- RGB group -->
                <TextBlock Text="RGB" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource SubText}" Margin="0,0,0,4"/>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="R:" FontSize="11" Foreground="#E05555"/>
                    <TextBox Name="RInput" Grid.Column="1" Height="22" TextChanged="RgbInput_Changed"/>
                </Grid>
                <Grid Margin="0,0,0,2">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="G:" FontSize="11" Foreground="#4CAF50"/>
                    <TextBox Name="GInput" Grid.Column="1" Height="22" TextChanged="RgbInput_Changed"/>
                </Grid>
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions><ColumnDefinition Width="20"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                    <TextBlock Text="B:" FontSize="11" Foreground="#569CD6"/>
                    <TextBox Name="BInput" Grid.Column="1" Height="22" TextChanged="RgbInput_Changed"/>
                </Grid>

                <!-- HEX -->
                <TextBlock Text="HEX" FontSize="9" FontWeight="Bold"
                           Foreground="{StaticResource SubText}" Margin="0,0,0,4"/>
                <TextBox Name="HexInput" Height="22" MaxLength="7"
                         TextChanged="HexInput_Changed"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
