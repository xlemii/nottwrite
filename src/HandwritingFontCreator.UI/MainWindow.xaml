<Window x:Class="HandwritingFontCreator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Handwriting Font Creator"
        Height="900"
        Width="1600"
        Background="{DynamicResource AppBg}">

    <Window.Resources>

        <!-- ═══ DARK THEME DEFAULTS ═══ -->
        <SolidColorBrush x:Key="AppBg"          Color="#1E1E1E"/>
        <SolidColorBrush x:Key="PanelBg"        Color="#252526"/>
        <SolidColorBrush x:Key="Surface2Bg"     Color="#2D2D30"/>
        <SolidColorBrush x:Key="AccentBrush"    Color="#569CD6"/>
        <SolidColorBrush x:Key="PrimaryText"    Color="#D4D4D4"/>
        <SolidColorBrush x:Key="SecondaryText"  Color="#858585"/>
        <SolidColorBrush x:Key="AppBorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="ButtonBg"       Color="#3C3C3C"/>
        <SolidColorBrush x:Key="CanvasBg"       Color="#1A1A1A"/>
        <SolidColorBrush x:Key="CharExistsBg"   Color="#1E3A1E"/>
        <SolidColorBrush x:Key="CharMissingBg"  Color="#3A1E1E"/>
        <SolidColorBrush x:Key="CharExistsFg"   Color="#6DB96D"/>
        <SolidColorBrush x:Key="CharMissingFg"  Color="#C96C6C"/>

        <!-- ═══ BUTTON STYLE ═══ -->
        <Style TargetType="Button">
            <Setter Property="Background"       Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground"       Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"      Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness"  Value="1"/>
            <Setter Property="Padding"          Value="12,0"/>
            <Setter Property="FontSize"         Value="12"/>
            <Setter Property="Cursor"           Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.4"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TEXTBOX STYLE ═══ -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource Surface2Bg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="6,4"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource PrimaryText}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource AccentBrush}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="3">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PROGRESSBAR STYLE ═══ -->
        <Style TargetType="ProgressBar">
            <Setter Property="Background"      Value="{DynamicResource Surface2Bg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Height"          Value="5"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}"
                                CornerRadius="2"
                                ClipToBounds="True">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        Background="{TemplateBinding Foreground}"
                                        CornerRadius="2"
                                        HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TEXTBLOCK STYLE ═══ -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>

        <!-- ═══ COMBOBOX STYLE ═══ -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <Border x:Name="Bd"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="3">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="24"/>
                                    </Grid.ColumnDefinitions>
                                    <ContentPresenter Grid.Column="0"
                                                      Content="{TemplateBinding SelectionBoxItem}"
                                                      ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                      Margin="{TemplateBinding Padding}"
                                                      VerticalAlignment="Center"
                                                      TextElement.Foreground="{TemplateBinding Foreground}"/>
                                    <TextBlock Grid.Column="1" Text="▾"
                                               Foreground="{TemplateBinding Foreground}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               FontSize="10"/>
                                </Grid>
                            </Border>
                            <Popup x:Name="PART_Popup"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Placement="Bottom">
                                <Border Background="{DynamicResource PanelBg}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="3">
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ COMBOBOXITEM STYLE ═══ -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground"  Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background"  Value="Transparent"/>
            <Setter Property="Padding"     Value="10,6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource Surface2Bg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ SLIDER STYLE ═══ -->
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            </Grid.RowDefinitions>
                            <Track Grid.Row="1" x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="{DynamicResource AccentBrush}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="4" Background="{DynamicResource Surface2Bg}" CornerRadius="2"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14" Height="14"
                                                         Fill="{DynamicResource AccentBrush}"
                                                         Stroke="{DynamicResource PanelBg}"
                                                         StrokeThickness="2"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ SCROLLBAR STYLE ═══ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="{DynamicResource AppBorderBrush}"
                                                        CornerRadius="3"
                                                        Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="56"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="340"/>
        </Grid.ColumnDefinitions>

        <!-- ════════════════════════════════════════
             TOP BAR
             ════════════════════════════════════════ -->
        <Border Grid.Row="0" Grid.ColumnSpan="3"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,0,1">

            <DockPanel Margin="12,0" LastChildFill="False">

                <!-- Template selector -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="Template" FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                    <ComboBox Name="TemplateComboBox" Width="110" Height="32"
                              SelectionChanged="TemplateComboBox_SelectionChanged"/>
                </StackPanel>

                <!-- Separator -->
                <Rectangle DockPanel.Dock="Left" Width="1" Margin="0,10,12,10"
                           Fill="{DynamicResource AppBorderBrush}"/>

                <!-- Export / Import -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button Height="32" Padding="12,0" Margin="0,0,5,0"
                            ToolTip="Eksportuj template do pliku .nwt"
                            Click="ExportTemplate_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="↑" FontSize="15" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,5,0"
                                       Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="Export" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Height="32" Padding="12,0"
                            ToolTip="Importuj template z pliku .nwt"
                            Click="ImportTemplate_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="↓" FontSize="15" FontWeight="Bold"
                                       VerticalAlignment="Center" Margin="0,0,5,0"
                                       Foreground="{DynamicResource AccentBrush}"/>
                            <TextBlock Text="Import" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Separator -->
                <Rectangle DockPanel.Dock="Left" Width="1" Margin="0,10,12,10"
                           Fill="{DynamicResource AppBorderBrush}"/>

                <!-- Undo / Redo -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button Height="32" Padding="12,0" Margin="0,0,5,0"
                            ToolTip="Cofnij (Ctrl+Z)" Click="UndoButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="↩" FontSize="15" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Undo" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Height="32" Padding="12,0"
                            ToolTip="Ponów (Ctrl+Y)" Click="RedoButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="↪" FontSize="15" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Redo" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Separator -->
                <Rectangle DockPanel.Dock="Left" Width="1" Margin="0,10,12,10"
                           Fill="{DynamicResource AppBorderBrush}"/>

                <!-- Save / Load -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,12,0">
                    <Button Height="32" Padding="14,0" Margin="0,0,5,0"
                            ToolTip="Zapisz literę (Ctrl+S)" Click="SaveButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="💾" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Save" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Height="32" Padding="14,0"
                            ToolTip="Wczytaj literę" Click="LoadButton_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="📂" FontSize="13" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="Load" FontSize="12" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Theme toggle (right-aligned) -->
                <Button DockPanel.Dock="Right" Name="ThemeToggleButton"
                        Content="☀  Light Mode" Width="118" Height="32"
                        VerticalAlignment="Center"
                        Click="ThemeToggleButton_Click"/>

                <!-- Separator -->
                <Rectangle DockPanel.Dock="Right" Width="1" Margin="12,10,12,10"
                           Fill="{DynamicResource AppBorderBrush}"/>

                <!-- Export dropdown (right-aligned) -->
                <Grid DockPanel.Dock="Right" VerticalAlignment="Center">
                    <Button Name="ExportMenuBtn" Height="32" Padding="14,0"
                            Click="ExportMenuBtn_Click">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Export" FontSize="12" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBlock Text="▾" FontSize="11" VerticalAlignment="Center"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </StackPanel>
                    </Button>
                    <Popup Name="ExportPopup" PlacementTarget="{Binding ElementName=ExportMenuBtn}"
                           Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                        <Border Background="{DynamicResource PanelBg}"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="1" CornerRadius="4"
                                Padding="6,6" MinWidth="160">
                            <StackPanel>
                                <Button Height="32" Padding="10,0" Margin="0,0,0,4"
                                        HorizontalContentAlignment="Left"
                                        Click="ExportPngButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="🖼" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock FontSize="12" VerticalAlignment="Center">
                                            <Run Text="Export " Foreground="{DynamicResource SecondaryText}"/>
                                            <Run Text="PNG" FontWeight="Bold"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                                <Button Height="32" Padding="10,0"
                                        HorizontalContentAlignment="Left"
                                        Click="ExportSvgButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="⬡" FontSize="13" Margin="0,0,8,0" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                        <TextBlock FontSize="12" VerticalAlignment="Center">
                                            <Run Text="Export " Foreground="{DynamicResource SecondaryText}"/>
                                            <Run Text="SVG" FontWeight="Bold"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

            </DockPanel>
        </Border>

        <!-- ════════════════════════════════════════
             LEFT PANEL — CHARACTERS + DRAWING SQUARE
             ════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.Column="0"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="260"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="10,6"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <StackPanel>
                        <TextBlock Text="CHARACTERS" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource SecondaryText}"
                                   Margin="0,0,0,5"/>
                        <!-- Add custom char row -->
                        <DockPanel>
                            <TextBlock Text="Add char" FontSize="10"
                                       Foreground="{DynamicResource SecondaryText}"
                                       VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <Button Name="AddCustomCharBtn"
                                    Content="+" DockPanel.Dock="Right"
                                    Width="26" Height="26" FontSize="14" FontWeight="Bold"
                                    ToolTip="Press key after clicking to add custom char"
                                    Click="AddCustomChar_Click"/>
                            <TextBox Name="CustomCharInput"
                                     Height="26" MaxLength="1"
                                     FontSize="13" FontWeight="Bold"
                                     TextAlignment="Center"
                                     Background="{DynamicResource Surface2Bg}"
                                     Foreground="{DynamicResource PrimaryText}"
                                     BorderBrush="{DynamicResource AppBorderBrush}"
                                     BorderThickness="1"
                                     VerticalContentAlignment="Center"
                                     ToolTip="Type a character to add it"
                                     TextChanged="CustomCharInput_TextChanged"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Scrollable character grid -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                              Background="Transparent">
                    <UniformGrid Name="CharacterGrid" Columns="4" Margin="8"/>
                </ScrollViewer>

                <!-- Drawing square header -->
                <Border Grid.Row="2" Padding="8,0"
                        MinHeight="40"
                        Background="{DynamicResource Surface2Bg}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,1,0,0">
                    <DockPanel VerticalAlignment="Center">

                        <!-- Current char label -->
                        <TextBlock Name="CurrentCharacterText"
                                   FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   FontFamily="Consolas"
                                   VerticalAlignment="Center"
                                   Margin="4,0,10,0"/>

                        <!-- Right-side tool buttons -->
                        <WrapPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                   VerticalAlignment="Center" Margin="0,4,0,4">

                            <!-- Variants -->
                            <Border Background="{DynamicResource AppBg}"
                                    CornerRadius="4" Margin="0,0,6,0" Padding="3,2">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="VAR" FontSize="9" FontWeight="Bold"
                                               Foreground="{DynamicResource SecondaryText}"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <Button Name="Var1Btn" Width="28" Height="26"
                                            FontSize="11" FontWeight="Bold"
                                            Margin="0,0,2,0" Click="VarBtn_Click" Tag="1">
                                        <TextBlock Text="1" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button Name="Var2Btn" Width="28" Height="26"
                                            FontSize="11" FontWeight="Bold"
                                            Margin="0,0,2,0" Click="VarBtn_Click" Tag="2">
                                        <TextBlock Text="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Button>
                                    <Button Name="Var3Btn" Width="28" Height="26"
                                            FontSize="11" FontWeight="Bold"
                                            Click="VarBtn_Click" Tag="3">
                                        <TextBlock Text="3" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </Border>

                            <!-- Ghost -->
                            <Button Name="GhostToggleBtn" Height="26" Padding="8,0"
                                    Margin="0,0,4,0"
                                    ToolTip="Pokaż/ukryj wzorzec litery"
                                    Click="GhostToggle_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="👁" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Ghost" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Options -->
                            <Button Name="DrawOptionsToggleBtn" Height="26" Padding="8,0"
                                    Margin="0,0,4,0"
                                    ToolTip="Opcje rysowania (taper, grubość)"
                                    Click="DrawOptionsToggle_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="⚙" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Style" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <!-- Clear -->
                            <Button Height="26" Padding="8,0"
                                    ToolTip="Wyczyść rysunek"
                                    Click="ClearButton_Click">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="✕" FontSize="12" FontWeight="Bold"
                                               Foreground="#E05555"
                                               VerticalAlignment="Center" Margin="0,0,4,0"/>
                                    <TextBlock Text="Clear" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                        </WrapPanel>
                    </DockPanel>
                </Border>

                <!-- Drawing canvas square -->
                <Canvas Grid.Row="3" Name="DrawingCanvas"
                        Background="{DynamicResource CanvasBg}"
                        MouseLeftButtonDown="DrawingCanvas_MouseLeftButtonDown"
                        MouseMove="DrawingCanvas_MouseMove"
                        MouseLeftButtonUp="DrawingCanvas_MouseLeftButtonUp"
                        ClipToBounds="True"/>

                <!-- Progress footer -->
                <Border Grid.Row="4" Padding="14,8"
                        Background="{DynamicResource Surface2Bg}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,5">
                            <TextBlock Text="Progress" FontSize="11"
                                       Foreground="{DynamicResource SecondaryText}"/>
                            <TextBlock Name="AlphabetProgressText" FontSize="11" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       HorizontalAlignment="Right"
                                       DockPanel.Dock="Right"/>
                        </DockPanel>
                        <ProgressBar Name="AlphabetProgressBar" Maximum="100"/>
                    </StackPanel>
                </Border>
                <!-- Draw Options panel (collapsible) -->
                <Border Grid.Row="5" Name="DrawOptionsPanel" Visibility="Collapsed"
                        Padding="12,10"
                        Background="{DynamicResource AppBg}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="0,2,0,0">
                    <StackPanel>
                        <TextBlock Text="STROKE STYLE" FontSize="9" FontWeight="Bold"
                                   Foreground="{DynamicResource SecondaryText}"
                                   Margin="0,0,0,8"/>
                        <!-- Taper amount -->
                        <DockPanel Margin="0,0,0,8">
                            <StackPanel DockPanel.Dock="Left" Width="80">
                                <TextBlock Text="Taper" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="tip narrowing" FontSize="9"
                                           Foreground="{DynamicResource SecondaryText}"/>
                            </StackPanel>
                            <TextBlock Name="TaperValueLabel" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       DockPanel.Dock="Right" VerticalAlignment="Center"
                                       Width="30" TextAlignment="Right"/>
                            <Slider Name="TaperSlider" Minimum="0" Maximum="10" Value="3.5"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    ValueChanged="TaperSlider_Changed"/>
                        </DockPanel>
                        <!-- Stroke thickness -->
                        <DockPanel Margin="0,0,0,10">
                            <StackPanel DockPanel.Dock="Left" Width="80">
                                <TextBlock Text="Width" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryText}"/>
                                <TextBlock Text="base line width" FontSize="9"
                                           Foreground="{DynamicResource SecondaryText}"/>
                            </StackPanel>
                            <TextBlock Name="StrokeWidthLabel" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource AccentBrush}"
                                       DockPanel.Dock="Right" VerticalAlignment="Center"
                                       Width="30" TextAlignment="Right"/>
                            <Slider Name="StrokeWidthSlider" Minimum="1" Maximum="12" Value="3.5"
                                    TickFrequency="0.5" IsSnapToTickEnabled="True"
                                    VerticalAlignment="Center"
                                    ValueChanged="StrokeWidthSlider_Changed"/>
                        </DockPanel>
                        <!-- Apply scope -->
                        <Border BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="0,1,0,0" Padding="0,8,0,0">
                            <DockPanel>
                                <TextBlock Text="Apply to:" FontSize="10"
                                           Foreground="{DynamicResource SecondaryText}"
                                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Height="28" Padding="10,0" Margin="0,0,5,0"
                                            Click="ApplyStrokeToLetter_Click">
                                        <TextBlock Text="This letter" FontSize="11" VerticalAlignment="Center"/>
                                    </Button>
                                    <Button Height="28" Padding="10,0"
                                            Click="ApplyStrokeToTemplate_Click">
                                        <TextBlock Text="Whole template" FontSize="11" VerticalAlignment="Center"/>
                                    </Button>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </StackPanel>
                </Border>

            </Grid>
        </Border>

        <!-- ════════════════════════════════════════
             CENTER PANEL — TEXT PREVIEW
             ════════════════════════════════════════ -->
        <Grid Grid.Row="1" Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <Border Grid.Row="0"
                    Background="{DynamicResource Surface2Bg}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,0">
                <TextBlock Text="PREVIEW" FontSize="10" FontWeight="Bold"
                           Foreground="{DynamicResource SecondaryText}"
                           VerticalAlignment="Center"/>
            </Border>

            <!-- Display-only canvas -->
            <ScrollViewer Grid.Row="1"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Auto"
                          Background="{DynamicResource CanvasBg}">
                <Canvas Name="DisplayCanvas"
                        Background="{DynamicResource CanvasBg}"/>
            </ScrollViewer>
        </Grid>

        <!-- ════════════════════════════════════════
             RIGHT PANEL — TEXT GENERATION
             ════════════════════════════════════════ -->
        <Border Grid.Row="1" Grid.Column="2"
                Background="{DynamicResource PanelBg}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1,0,0,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Header -->
                <Border Grid.Row="0" Padding="14,10"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <TextBlock Text="GENERATE TEXT" FontSize="10" FontWeight="Bold"
                               Foreground="{DynamicResource SecondaryText}"/>
                </Border>

                <!-- Text input + font size -->
                <StackPanel Grid.Row="1" Margin="12,12,12,0">

                    <!-- Formatting toolbar -->
                    <Border Margin="0,0,0,4"
                            Background="{DynamicResource Surface2Bg}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1" CornerRadius="3"
                            Padding="4,3">
                        <WrapPanel Orientation="Horizontal">
                            <!-- Bold / Italic -->
                            <Button Name="BoldBtn" Width="28" Height="26" Margin="2,1"
                                    FontWeight="Bold" Content="B" FontSize="13"
                                    ToolTip="Bold (Ctrl+B)"
                                    Click="BoldBtn_Click"/>
                            <Button Name="ItalicBtn" Width="28" Height="26" Margin="2,1"
                                    FontStyle="Italic" Content="I" FontSize="13"
                                    ToolTip="Italic (Ctrl+I)"
                                    Click="ItalicBtn_Click"/>
                            <!-- Separator -->
                            <Rectangle Width="1" Margin="5,3" Fill="{DynamicResource AppBorderBrush}"/>
                            <!-- Color swatches -->
                            <Button Width="22" Height="22" Margin="2,2" ToolTip="Default"
                                    Tag="Default" Click="ColorBtn_Click">
                                <Button.Background><SolidColorBrush Color="#E8E8E8"/></Button.Background>
                            </Button>
                            <Button Width="22" Height="22" Margin="2,2" ToolTip="Red"
                                    Tag="Red" Click="ColorBtn_Click">
                                <Button.Background><SolidColorBrush Color="#E05555"/></Button.Background>
                            </Button>
                            <Button Width="22" Height="22" Margin="2,2" ToolTip="Green"
                                    Tag="Green" Click="ColorBtn_Click">
                                <Button.Background><SolidColorBrush Color="#4CAF50"/></Button.Background>
                            </Button>
                            <Button Width="22" Height="22" Margin="2,2" ToolTip="Blue"
                                    Tag="Blue" Click="ColorBtn_Click">
                                <Button.Background><SolidColorBrush Color="#569CD6"/></Button.Background>
                            </Button>
                            <Button Width="22" Height="22" Margin="2,2" ToolTip="Yellow"
                                    Tag="Yellow" Click="ColorBtn_Click">
                                <Button.Background><SolidColorBrush Color="#E5C07B"/></Button.Background>
                            </Button>
                            <Button Width="22" Height="22" Margin="2,2" ToolTip="Orange"
                                    Tag="Orange" Click="ColorBtn_Click">
                                <Button.Background><SolidColorBrush Color="#E0845A"/></Button.Background>
                            </Button>
                            <Button Width="22" Height="22" Margin="2,2" ToolTip="Purple"
                                    Tag="Purple" Click="ColorBtn_Click">
                                <Button.Background><SolidColorBrush Color="#C792EA"/></Button.Background>
                            </Button>
                        </WrapPanel>
                    </Border>

                    <!-- Rich text box -->
                    <RichTextBox Name="GenerateRichBox"
                                 Height="200"
                                 VerticalScrollBarVisibility="Auto"
                                 Background="{DynamicResource Surface2Bg}"
                                 Foreground="{DynamicResource PrimaryText}"
                                 BorderBrush="{DynamicResource AppBorderBrush}"
                                 BorderThickness="1"
                                 Padding="6,4"
                                 FontFamily="Segoe UI"
                                 FontSize="13"
                                 Margin="0,0,0,12"
                                 TextChanged="GenerateRichBox_TextChanged"/>

                    <!-- Font size -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Font Size" FontSize="11"
                                   Foreground="{DynamicResource SecondaryText}"/>
                        <TextBlock Name="FontSizeLabel" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                    </DockPanel>
                    <Slider Name="FontSizeSlider"
                            Minimum="40" Maximum="400" Value="180"
                            TickFrequency="10" IsSnapToTickEnabled="True"
                            ValueChanged="FontSizeSlider_Changed"
                            Margin="0,0,0,10"/>

                    <!-- Letter spacing -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Letter Spacing" FontSize="11"
                                   Foreground="{DynamicResource SecondaryText}"/>
                        <TextBlock Name="LetterSpacingLabel" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                    </DockPanel>
                    <Slider Name="LetterSpacingSlider"
                            Minimum="-20" Maximum="80" Value="0"
                            TickFrequency="2" IsSnapToTickEnabled="True"
                            ValueChanged="LetterSpacingSlider_Changed"
                            Margin="0,0,0,10"/>

                    <!-- Stroke width -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Stroke Width" FontSize="11"
                                   Foreground="{DynamicResource SecondaryText}"/>
                        <TextBlock Name="GenStrokeWidthLabel" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                    </DockPanel>
                    <Slider Name="GenStrokeWidthSlider"
                            Minimum="0.5" Maximum="10" Value="3.5"
                            TickFrequency="0.5" IsSnapToTickEnabled="True"
                            ValueChanged="GenStrokeWidthSlider_Changed"
                            Margin="0,0,0,10"/>

                    <!-- Divider -->
                    <Border BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="0,1,0,0" Margin="0,0,0,10"/>

                    <!-- Line Spacing -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Line Spacing" FontSize="11"
                                   Foreground="{DynamicResource SecondaryText}"/>
                        <TextBlock Name="SpacingLabel" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                    </DockPanel>
                    <Slider Name="SpacingSlider" Minimum="20" Maximum="300" Value="100"
                            TickFrequency="10" IsSnapToTickEnabled="True"
                            ValueChanged="SpacingSlider_Changed"
                            Margin="0,0,0,10"/>

                    <!-- Line Thickness -->
                    <DockPanel Margin="0,0,0,4">
                        <TextBlock Text="Line Thickness" FontSize="11"
                                   Foreground="{DynamicResource SecondaryText}"/>
                        <TextBlock Name="ThicknessLabel" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                    </DockPanel>
                    <Slider Name="ThicknessSlider" Minimum="0.5" Maximum="6" Value="1"
                            TickFrequency="0.5" IsSnapToTickEnabled="True"
                            ValueChanged="ThicknessSlider_Changed"
                            Margin="0,0,0,16"/>

                </StackPanel>

                <!-- Action buttons footer -->
                <Border Grid.Row="2" Padding="12,10"
                        Background="{DynamicResource Surface2Bg}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,1,0,0">
                    <StackPanel>
                        <Button Content="Generate" Height="32" Margin="0,0,0,6"
                                Click="GenerateButton_Click"/>
                        <Button Content="Preview All" Height="32"
                                Click="PreviewAlphabetButton_Click"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

    </Grid>
</Window>
