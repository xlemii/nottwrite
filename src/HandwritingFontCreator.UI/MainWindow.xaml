<Window x:Class="HandwritingFontCreator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="nottwrite"
        Height="900" Width="1400" MinHeight="600" MinWidth="900"
        WindowStyle="None"
        Background="#1E1E1E"
        Icon="pack://application:,,,/icon.png"
        FontFamily="pack://application:,,,/Fonts/geist-font/Geist/ttf/#Geist"
        PreviewKeyDown="Window_PreviewKeyDown">

    <!-- WindowChrome: frameless + resize support -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="5"
                            GlassFrameThickness="0" CornerRadius="8"/>
    </shell:WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Save}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Undo}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Redo}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}"  Executed="SaveCommand_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Undo}"  Executed="UndoCommand_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Redo}"  Executed="RedoCommand_Executed"/>
    </Window.CommandBindings>

    <Window.Resources>
        <!-- ═══════════════════════════════════════════════════════
             PALETTE — deep dark + violet accent
             ═══════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="AppBg"           Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TitleBarBg"      Color="#202020"/>
        <SolidColorBrush x:Key="PanelBg"         Color="#282828"/>
        <SolidColorBrush x:Key="Surface2Bg"      Color="#242424"/>
        <SolidColorBrush x:Key="CardBg"          Color="#2E2E2E"/>
        <SolidColorBrush x:Key="CardBg2"         Color="#363636"/>
        <SolidColorBrush x:Key="AccentBrush"     Color="#8B7DC4"/>
        <SolidColorBrush x:Key="AccentHover"     Color="#A898D8"/>
        <SolidColorBrush x:Key="NavActiveBg"     Color="#3A3260"/>
        <SolidColorBrush x:Key="ButtonBg"        Color="#2E2E2E"/>
        <SolidColorBrush x:Key="PrimaryText"     Color="#F0F0F0"/>
        <SolidColorBrush x:Key="SecondaryText"   Color="#888888"/>
        <SolidColorBrush x:Key="AppBorderBrush"  Color="#333333"/>
        <SolidColorBrush x:Key="CanvasBg"        Color="#141414"/>
        <SolidColorBrush x:Key="DangerBrush"     Color="#EF4444"/>
        <SolidColorBrush x:Key="SuccessBrush"    Color="#4ADE80"/>
        <SolidColorBrush x:Key="CharExistsBg"    Color="#162016"/>
        <SolidColorBrush x:Key="CharMissingBg"   Color="#201616"/>
        <SolidColorBrush x:Key="CharExistsFg"    Color="#4ADE80"/>
        <SolidColorBrush x:Key="CharMissingFg"   Color="#F87171"/>
        <SolidColorBrush x:Key="StrokeBrush"     Color="#E8E8E8"/>
        <SolidColorBrush x:Key="LoadedStrokeBrush" Color="#888888"/>
        <SolidColorBrush x:Key="NotebookLineBrush" Color="#2E2E44"/>

        <!-- ═══ SECTION LABEL ═══════════════════════════════════ -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- ═══ DEFAULT BUTTON — hover overlay + scale ══════════ -->
        <Style TargetType="Button">
            <Setter Property="Background"          Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground"          Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"         Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="Padding"             Value="12,0"/>
            <Setter Property="FontSize"            Value="12"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="BdScale"/>
                            </Border.RenderTransform>
                            <Grid>
                                <Border x:Name="HoverLayer" CornerRadius="5"
                                        Background="White" Opacity="0"
                                        IsHitTestVisible="False"/>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.07" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.94" Duration="0:0:0.07"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.94" Duration="0:0:0.07"/>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.14" Duration="0:0:0.07"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1" Duration="0:0:0.14"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ NAV BUTTON — Fluent left-accent nav item ════════ -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"         Value="Transparent"/>
            <Setter Property="Foreground"         Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"        Value="Transparent"/>
            <Setter Property="BorderThickness"    Value="3,0,0,0"/>
            <Setter Property="Cursor"             Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Height="40">
                            <!-- Left accent bar -->
                            <Border Width="3" HorizontalAlignment="Left"
                                    Background="{TemplateBinding BorderBrush}"
                                    VerticalAlignment="Stretch"/>
                            <!-- Background + hover -->
                            <Border x:Name="Bg" Margin="3,2,6,2" CornerRadius="6"
                                    Background="{TemplateBinding Background}">
                                <Grid>
                                    <Border x:Name="HoverLayer" CornerRadius="5"
                                            Background="White" Opacity="0"
                                            IsHitTestVisible="False"/>
                                    <ContentPresenter HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Margin="12,0"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.06" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ CHROME BUTTON — min/max/close ═══════════════════ -->
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Foreground"     Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"          Value="46"/>
            <Setter Property="Height"         Value="32"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="FontSize"       Value="10"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#3A3A3A" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="Transparent" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ CLOSE BUTTON ════════════════════════════════════ -->
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource ChromeBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}" CornerRadius="0,8,0,0">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="#C42B1C" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <ColorAnimation Storyboard.TargetName="Bd"
                                            Storyboard.TargetProperty="(Border.Background).(SolidColorBrush.Color)"
                                            To="Transparent" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TEXTBOX ═════════════════════════════════════════ -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource CardBg2}"/>
            <Setter Property="Foreground"      Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource NavActiveBg}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TBd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="TBd" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PROGRESSBAR ═════════════════════════════════════ -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height"          Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="#333333" CornerRadius="2" ClipToBounds="True">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" CornerRadius="2"
                                        HorizontalAlignment="Left">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Color="#8B7DC4" Offset="0"/>
                                            <GradientStop Color="#A898D8" Offset="1"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TEXTBLOCK ═══════════════════════════════════════ -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>

        <!-- ═══ COMBOBOX ════════════════════════════════════════ -->
        <Style TargetType="ComboBox">
            <Setter Property="Background"      Value="{DynamicResource CardBg}"/>
            <Setter Property="Foreground"      Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <ToggleButton x:Name="DropDownToggle" Focusable="False"
                                          IsChecked="{Binding Path=IsDropDownOpen, Mode=TwoWay,
                                              RelativeSource={RelativeSource TemplatedParent}}"
                                          Background="{TemplateBinding Background}"
                                          BorderBrush="{TemplateBinding BorderBrush}"
                                          BorderThickness="{TemplateBinding BorderThickness}"
                                          Cursor="Hand">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="TBd" Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6">
                                            <TextBlock Text="&#x25BE;" FontSize="9"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="TBd" Property="BorderBrush"
                                                        Value="{DynamicResource AccentBrush}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <ContentPresenter IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              Margin="10,0,26,0" VerticalAlignment="Center"
                                              TextElement.Foreground="{TemplateBinding Foreground}"
                                              TextElement.FontSize="11"/>
                            <Popup x:Name="PART_Popup" IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True" Placement="Bottom" StaysOpen="False">
                                <Border Background="{DynamicResource CardBg}"
                                        BorderBrush="{DynamicResource AccentBrush}"
                                        BorderThickness="1" CornerRadius="8" Padding="4"
                                        MinWidth="{Binding ActualWidth,
                                            RelativeSource={RelativeSource AncestorType=ComboBox}}">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000" BlurRadius="24"
                                                          ShadowDepth="6" Opacity="0.5"/>
                                    </Border.Effect>
                                    <ScrollViewer MaxHeight="200">
                                        <ItemsPresenter/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ COMBOBOXITEM ════════════════════════════════════ -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding"    Value="10,6"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}" CornerRadius="5">
                            <ContentPresenter TextElement.Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3A3A"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource NavActiveBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ SLIDER ══════════════════════════════════════════ -->
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            </Grid.RowDefinitions>
                            <Track Grid.Row="1" x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" CornerRadius="1.5">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                            <GradientStop Color="#9B59FC" Offset="0"/>
                                                            <GradientStop Color="#AE7BFD" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                </Border>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" Background="#3A3A3A" CornerRadius="1.5"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14" Height="14"
                                                         Fill="{DynamicResource AccentBrush}"
                                                         Stroke="{DynamicResource CanvasBg}" StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#8B7DC4"
                                                            BlurRadius="6" ShadowDepth="0"
                                                            Opacity="0.5"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ SCROLLBAR ═══════════════════════════════════════ -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width"      Value="4"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#4A4A4A" CornerRadius="2"
                                                        Margin="1,0"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TOGGLE OFF STYLE ════════════════════════════════ -->
        <Style x:Key="ToggleOffBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"   Value="{DynamicResource CardBg2}"/>
            <Setter Property="FontSize"     Value="9"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Padding"      Value="6,2"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource AppBorderBrush}"/>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════
         ROOT GRID
         ═══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Title bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- hidden compat elements -->
        <skia:SKElement Name="SkiaCanvas" Width="0" Height="0" Visibility="Collapsed"
                        PaintSurface="SkiaCanvas_PaintSurface"/>
        <Canvas Name="InputCanvas" Width="0" Height="0" Visibility="Collapsed"/>

        <!-- ╔══════════════════════════════════════════════════════╗
             ║  CUSTOM TITLE BAR                                   ║
             ╚══════════════════════════════════════════════════════╝ -->
        <Grid Grid.Row="0" Background="{DynamicResource TitleBarBg}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Brand + Template controls -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="14,0,0,0">

                <!-- App name -->
                <TextBlock Text="nottwrite" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryText}"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>

                <!-- Divider -->
                <Rectangle Width="1" Height="22" Fill="{DynamicResource AppBorderBrush}"
                           Margin="0,0,16,0"/>

                <!-- Template section -->
                <TextBlock Text="Template" FontSize="10"
                           Foreground="{DynamicResource SecondaryText}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>
                <ComboBox Name="TemplateComboBox" Width="120" Height="30"
                          SelectionChanged="TemplateComboBox_SelectionChanged"
                          shell:WindowChrome.IsHitTestVisibleInChrome="True"/>
                <Button Width="30" Height="30" Margin="5,0,0,0" Padding="0"
                        ToolTip="New template" Click="NewTemplate_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="+" FontSize="18" FontWeight="Light"
                               Foreground="{DynamicResource AccentBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"
                               Margin="0,-2,0,0"/>
                </Button>
                <Button Name="SetDefaultTemplateBtn" Width="30" Height="30" Margin="3,0,0,0"
                        Padding="0" ToolTip="Set as default"
                        Click="SetDefaultTemplate_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Name="DefaultStarLabel" Text="&#x2606;" FontSize="14"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <Button Width="30" Height="30" Margin="3,0,0,0" Padding="0"
                        ToolTip="Delete template" Click="DeleteTemplate_Click"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="&#x2715;" FontSize="12" FontWeight="Bold"
                               Foreground="{DynamicResource DangerBrush}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>

                <!-- Divider -->
                <Rectangle Width="1" Height="22" Fill="{DynamicResource AppBorderBrush}"
                           Margin="14,0,14,0"/>

                <!-- Export / Import / SVG -->
                <Button Height="30" Padding="10,0" Margin="0,0,4,0"
                        Click="ExportTemplate_Click" ToolTip="Export template (.nwt)"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x2191;" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Export" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Height="30" Padding="10,0" Margin="0,0,4,0"
                        Click="ImportTemplate_Click" ToolTip="Import template (.nwt)"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x2193;" FontSize="13" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="Import" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Height="30" Padding="10,0"
                        Click="ExportSvgButton_Click" ToolTip="Export as SVG"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#x2B21;" FontSize="11" FontWeight="Bold"
                                   Foreground="{DynamicResource AccentBrush}"
                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="SVG" FontSize="11" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- Right: Save As + Chrome buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center">
                <!-- Save As -->
                <Grid Margin="0,0,10,0"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Name="ExportMenuBtn" Height="30" Padding="14,0"
                            BorderThickness="0" Click="ExportMenuBtn_Click">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8B7DC4" Offset="0"/>
                                <GradientStop Color="#6A5FA8" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Save As" FontSize="11" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"
                                       Margin="0,0,5,0"/>
                            <TextBlock Text="&#x25BE;" FontSize="10" Foreground="White"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Popup Name="ExportPopup"
                           PlacementTarget="{Binding ElementName=ExportMenuBtn}"
                           Placement="Bottom" StaysOpen="False"
                           AllowsTransparency="True" VerticalOffset="4">
                        <Border Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="6" MinWidth="160">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" BlurRadius="28"
                                                  ShadowDepth="6" Opacity="0.6"/>
                            </Border.Effect>
                            <StackPanel>
                                <Button Height="36" Padding="10,0" Margin="0,0,0,3"
                                        HorizontalContentAlignment="Left"
                                        Click="ExportPngButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="22" Height="22" CornerRadius="4"
                                                Background="#1E3A5F" Margin="0,0,9,0">
                                            <TextBlock Text="P" FontSize="10" FontWeight="Bold"
                                                       Foreground="#60A5FA"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="PNG" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Height="36" Padding="10,0" Margin="0,0,0,3"
                                        HorizontalContentAlignment="Left"
                                        Click="ExportJpgButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="22" Height="22" CornerRadius="4"
                                                Background="#3B1F1F" Margin="0,0,9,0">
                                            <TextBlock Text="J" FontSize="10" FontWeight="Bold"
                                                       Foreground="#F87171"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="JPG" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Height="36" Padding="10,0"
                                        HorizontalContentAlignment="Left"
                                        Click="ExportPdfButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="22" Height="22" CornerRadius="4"
                                                Background="#3B2020" Margin="0,0,9,0">
                                            <TextBlock Text="&#x1F4C4;" FontSize="11"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="PDF" FontSize="12"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Divider -->
                <Rectangle Width="1" Height="22" Fill="{DynamicResource AppBorderBrush}"
                           Margin="0,0,0,0"/>

                <!-- Window chrome buttons -->
                <Button Style="{StaticResource ChromeBtn}"
                        Click="BtnSettings_Click"
                        ToolTip="Settings"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="&#x2699;" FontSize="12"
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>

                <Button Style="{StaticResource ChromeBtn}"
                        Click="BtnMinimize_Click"
                        ToolTip="Minimise">
                    <TextBlock Text="&#x268A;" FontSize="11"
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource ChromeBtn}"
                        Click="BtnMaximize_Click"
                        ToolTip="Maximise / Restore">
                    <TextBlock Text="&#x2750;" FontSize="9"
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource CloseBtn}"
                        Click="BtnClose_Click"
                        ToolTip="Close">
                    <TextBlock Text="&#x2715;" FontSize="10"
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ╔══════════════════════════════════════════════════════╗
             ║  MAIN CONTENT                                       ║
             ╚══════════════════════════════════════════════════════╝ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="265"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT SIDEBAR ════════════════════════════════════ -->
            <Grid Grid.Column="0" Background="{DynamicResource PanelBg}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Mode nav -->
                    <RowDefinition Height="*"/>     <!-- Settings -->
                </Grid.RowDefinitions>

                <!-- Mode Navigation -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,0,0,1" Padding="0,6,0,6">
                    <StackPanel>
                        <Button Name="EditModeBtn"
                                Style="{StaticResource NavBtn}"
                                Click="EditModeBtn_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x270F;" FontSize="15" Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Edit" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="draw characters" FontSize="9"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Name="TypeModeBtn"
                                Style="{StaticResource NavBtn}"
                                Click="TypeModeBtn_Click"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x270D;" FontSize="15" Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Type" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="write on paper" FontSize="9"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Settings panels (Edit / Type) -->
                <Grid Grid.Row="1">

                    <!-- ── EDIT SETTINGS ──────────────────────────── -->
                    <Border Name="EditLeftPanel">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Toolbar -->
                            <Border Grid.Row="0" Padding="10,8"
                                    Background="{DynamicResource Surface2Bg}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Name="EditActiveCharLabel" Visibility="Collapsed"/>
                                    <WrapPanel>
                                        <Button Name="GhostToggleBtn" Height="28" Padding="8,0"
                                                Margin="0,0,3,3"
                                                ToolTip="Ghost" Click="GhostToggle_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x1F441;" FontSize="11"
                                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Ghost" FontSize="10" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Name="EraserBtn" Height="28" Padding="8,0"
                                                Margin="0,0,3,3"
                                                ToolTip="Eraser (E)" Click="EraserBtn_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x232B;" FontSize="11"
                                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Erase" FontSize="10" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Height="28" Padding="8,0" Margin="0,0,3,3"
                                                ToolTip="Undo" Click="UndoButton_Click">
                                            <TextBlock Text="&#x21A9;" FontSize="13"/>
                                        </Button>
                                        <Button Height="28" Padding="8,0" Margin="0,0,3,3"
                                                ToolTip="Redo" Click="RedoButton_Click">
                                            <TextBlock Text="&#x21AA;" FontSize="13"/>
                                        </Button>
                                        <Button Height="28" Padding="8,0" Margin="0,0,3,3"
                                                ToolTip="Clear" Click="ClearButton_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x2715;" FontSize="10" FontWeight="Bold"
                                                           Foreground="{DynamicResource DangerBrush}"
                                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Clear" FontSize="10" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Border Name="EditCharColorSwatch" Visibility="Collapsed"
                                                Width="0" Height="0"
                                                MouseLeftButtonDown="EditCharColorSwatch_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Scrollable settings -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          Background="Transparent"
                                          ClipToBounds="True">
                                <StackPanel Margin="10,10,10,10">

                                    <TextBlock Text="BRUSH SHAPE" Style="{StaticResource SectionLabel}"/>

                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="8" Margin="0,0,0,10">
                                        <WrapPanel>
                                            <Button Name="BrushRoundBtn"    Width="40" Height="30"
                                                    Margin="0,0,3,3" Tag="Round"
                                                    Click="BrushShape_Click" ToolTip="Round">
                                                <TextBlock Text="&#x25CF;" FontSize="13"/>
                                            </Button>
                                            <Button Name="BrushFlatBtn"     Width="40" Height="30"
                                                    Margin="0,0,3,3" Tag="Flat"
                                                    Click="BrushShape_Click" ToolTip="Flat">
                                                <TextBlock Text="&#x25AC;" FontSize="13"/>
                                            </Button>
                                            <Button Name="BrushCalligBtn"   Width="40" Height="30"
                                                    Margin="0,0,3,3" Tag="Calligraphy"
                                                    Click="BrushShape_Click" ToolTip="Calligraphy">
                                                <TextBlock Text="&#x2712;" FontSize="13"/>
                                            </Button>
                                            <Button Name="BrushTriangleBtn" Width="40" Height="30"
                                                    Margin="0,0,3,3" Tag="Triangle"
                                                    Click="BrushShape_Click" ToolTip="Triangle">
                                                <TextBlock Text="&#x25B2;" FontSize="11"/>
                                            </Button>
                                            <Button Name="BrushInkBtn"      Width="40" Height="30"
                                                    Margin="0,0,3,3" Tag="Ink"
                                                    Click="BrushShape_Click" ToolTip="Ink">
                                                <TextBlock Text="&#x1F58B;" FontSize="12"/>
                                            </Button>
                                            <Button Name="BrushChiselBtn"   Width="40" Height="30"
                                                    Margin="0,0,0,3" Tag="Chisel"
                                                    Click="BrushShape_Click" ToolTip="Chisel">
                                                <TextBlock Text="&#x2571;" FontSize="13"/>
                                            </Button>
                                        </WrapPanel>
                                    </Border>

                                    <!-- Brush preview -->
                                    <Border CornerRadius="8" Height="48"
                                            Background="{DynamicResource CanvasBg}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1" Margin="0,0,0,12">
                                        <skia:SKElement Name="BrushPreviewCanvas"
                                                        PaintSurface="BrushPreviewCanvas_PaintSurface"/>
                                    </Border>

                                    <TextBlock Text="SETTINGS" Style="{StaticResource SectionLabel}"/>

                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="12,10" Margin="0,0,0,4">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Size" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="BrushSizeLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="BrushSizeSlider" Minimum="1" Maximum="24"
                                                    Value="3.5" TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="BrushSizeSlider_Changed"
                                                    Margin="0,0,0,10"/>

                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Taper" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           VerticalAlignment="Center"/>
                                                <Button Name="TaperToggleBtn" Width="42" Height="20"
                                                        DockPanel.Dock="Right" Margin="4,0,0,0"
                                                        Style="{StaticResource ToggleOffBtn}"
                                                        Click="TaperToggle_Click">
                                                    <TextBlock Name="TaperToggleLabel" Text="OFF"
                                                               FontSize="9" FontWeight="Bold"/>
                                                </Button>
                                                <TextBlock Name="TaperValueLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="TaperSlider" Minimum="0" Maximum="10"
                                                    Value="0" TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="TaperSlider_Changed"
                                                    Margin="0,0,0,10"/>

                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Tip Roundness" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="TipRoundnessLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="TipRoundnessSlider" Minimum="0" Maximum="1"
                                                    Value="1" TickFrequency="0.05"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="TipRoundness_Changed"
                                                    Margin="0,0,0,10"/>

                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Opacity" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="BrushOpacityLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="BrushOpacitySlider" Minimum="10"
                                                    Maximum="100" Value="100" TickFrequency="5"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="BrushOpacity_Changed"
                                                    Margin="0,0,0,10"/>

                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Smoothing" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="BrushSmoothLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="BrushSmoothSlider" Minimum="0" Maximum="5"
                                                    Value="2" TickFrequency="1"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="BrushSmooth_Changed"
                                                    Margin="0,0,0,10"/>

                                            <StackPanel Name="CalligAnglePanel" Visibility="Collapsed">
                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Callig Angle" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"/>
                                                    <TextBlock Name="CalligAngleLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="CalligAngleSlider" Minimum="0"
                                                        Maximum="90" Value="45" TickFrequency="5"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="CalligAngle_Changed"
                                                        Margin="0,0,0,10"/>
                                            </StackPanel>

                                            <DockPanel>
                                                <TextBlock Text="Pressure" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           VerticalAlignment="Center"/>
                                                <Button Name="PressureToggleBtn" Width="42" Height="20"
                                                        DockPanel.Dock="Right"
                                                        Style="{StaticResource ToggleOffBtn}"
                                                        Click="PressureToggle_Click">
                                                    <TextBlock Name="PressureToggleLabel" Text="OFF"
                                                               FontSize="9" FontWeight="Bold"/>
                                                </Button>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- Inline color picker -->
                            <Border Grid.Row="2" Padding="10,10"
                                    Background="{DynamicResource Surface2Bg}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,7">
                                        <TextBlock Text="CHAR COLOR" Style="{StaticResource SectionLabel}"
                                                   Margin="0" VerticalAlignment="Center"/>
                                        <Border Name="InlineColorPreview" Width="34" Height="16"
                                                CornerRadius="4" Background="#E8E8E8"
                                                BorderBrush="{DynamicResource AppBorderBrush}"
                                                BorderThickness="1"
                                                HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                                    </DockPanel>
                                    <Grid Height="128">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="16"/>
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="98"/>
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" CornerRadius="6"
                                                BorderBrush="{DynamicResource AppBorderBrush}"
                                                BorderThickness="1" ClipToBounds="True">
                                            <Grid>
                                                <skia:SKElement Name="InlineSvCanvas"
                                                                PaintSurface="InlineSvCanvas_Paint"
                                                                IsHitTestVisible="False"/>
                                                <Canvas Name="InlineSvInput" Background="Transparent"
                                                        MouseLeftButtonDown="InlineSvInput_MouseDown"
                                                        MouseMove="InlineSvInput_MouseMove"
                                                        MouseLeftButtonUp="InlineSvInput_MouseUp"/>
                                            </Grid>
                                        </Border>
                                        <Border Grid.Column="2" CornerRadius="4"
                                                BorderBrush="{DynamicResource AppBorderBrush}"
                                                BorderThickness="1" ClipToBounds="True">
                                            <Grid>
                                                <skia:SKElement Name="InlineHueCanvas"
                                                                PaintSurface="InlineHueCanvas_Paint"
                                                                IsHitTestVisible="False"/>
                                                <Canvas Name="InlineHueInput" Background="Transparent"
                                                        MouseLeftButtonDown="InlineHueInput_MouseDown"
                                                        MouseMove="InlineHueInput_MouseMove"
                                                        MouseLeftButtonUp="InlineHueInput_MouseUp"/>
                                            </Grid>
                                        </Border>
                                        <StackPanel Grid.Column="4" VerticalAlignment="Top">
                                            <TextBlock Text="RGB" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       Margin="0,0,0,3"/>
                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="15"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="R:" FontSize="10" Foreground="#F87171"/>
                                                <TextBox Name="InlineRInput" Grid.Column="1" Height="22"
                                                         FontSize="10" Padding="4,2"
                                                         TextChanged="InlineRgbInput_Changed"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="15"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="G:" FontSize="10" Foreground="#4ADE80"/>
                                                <TextBox Name="InlineGInput" Grid.Column="1" Height="22"
                                                         FontSize="10" Padding="4,2"
                                                         TextChanged="InlineRgbInput_Changed"/>
                                            </Grid>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="15"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="B:" FontSize="10" Foreground="#60A5FA"/>
                                                <TextBox Name="InlineBInput" Grid.Column="1" Height="22"
                                                         FontSize="10" Padding="4,2"
                                                         TextChanged="InlineRgbInput_Changed"/>
                                            </Grid>
                                            <TextBlock Text="HEX" FontSize="9" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       Margin="0,0,0,3"/>
                                            <TextBox Name="InlineHexInput" Height="22" FontSize="10"
                                                     MaxLength="7" Padding="4,2"
                                                     TextChanged="InlineHexInput_Changed"/>
                                        </StackPanel>
                                    </Grid>
                                </StackPanel>
                            </Border>

                            <!-- Progress -->
                            <Border Grid.Row="3" Padding="12,8"
                                    Background="{DynamicResource Surface2Bg}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,5">
                                        <TextBlock Text="Progress" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryText}"/>
                                        <TextBlock Name="AlphabetProgressText" FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                                    </DockPanel>
                                    <ProgressBar Name="AlphabetProgressBar" Maximum="100"/>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </Border>

                    <!-- ── TYPE SETTINGS ──────────────────────────── -->
                    <Border Name="TypeLeftPanel" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="10,8"
                                    Background="{DynamicResource Surface2Bg}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <TextBlock Text="STYLE" FontSize="9" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryText}"
                                               VerticalAlignment="Center"/>
                                    <WrapPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                               HorizontalAlignment="Right">
                                        <Button Name="BoldBtn" Width="30" Height="26" Margin="3,0"
                                                ToolTip="Bold (Ctrl+B)" Click="BoldBtn_Click">
                                            <TextBlock FontWeight="Bold" FontSize="13"
                                                       FontFamily="Georgia" Text="B"/>
                                        </Button>
                                        <Button Name="ItalicBtn" Width="30" Height="26" Margin="3,0"
                                                ToolTip="Italic (Ctrl+I)" Click="ItalicBtn_Click">
                                            <TextBlock FontStyle="Italic" FontSize="13"
                                                       FontFamily="Georgia" Text="I"/>
                                        </Button>
                                        <Border Name="TypeColorSwatch" Width="22" Height="22"
                                                Margin="5,0,2,0" CornerRadius="6"
                                                Background="#E8E8E8"
                                                BorderBrush="{DynamicResource AppBorderBrush}"
                                                BorderThickness="1" Cursor="Hand"
                                                MouseLeftButtonDown="TypeColorSwatch_Click"/>
                                    </WrapPanel>
                                </DockPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          Padding="10,10,10,10"
                                          ClipToBounds="True">
                                <StackPanel>

                                    <TextBlock Text="TYPOGRAPHY" Style="{StaticResource SectionLabel}"/>
                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Font Size" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="FontSizeLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="FontSizeSlider" Minimum="40" Maximum="400"
                                                    Value="180" TickFrequency="10"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="FontSizeSlider_Changed"
                                                    Margin="0,0,0,10"/>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Letter Spacing" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="LetterSpacingLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="LetterSpacingSlider" Minimum="-20"
                                                    Maximum="80" Value="0" TickFrequency="2"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="LetterSpacingSlider_Changed"
                                                    Margin="0,0,0,10"/>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Word Spacing" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="WordSpacingLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="WordSpacingSlider" Minimum="-20"
                                                    Maximum="120" Value="0" TickFrequency="4"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="WordSpacingSlider_Changed"
                                                    Margin="0,0,0,10"/>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Line Height" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="LineHeightLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="LineHeightSlider" Minimum="0.8"
                                                    Maximum="4.0" Value="1.6" TickFrequency="0.1"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="LineHeightSlider_Changed"
                                                    Margin="0,0,0,10"/>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Stroke Width" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="GenStrokeWidthLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="GenStrokeWidthSlider" Minimum="0.5"
                                                    Maximum="10" Value="3.5" TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="GenStrokeWidthSlider_Changed"
                                                    Margin="0,0,0,2"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="NATURAL FEEL" Style="{StaticResource SectionLabel}"/>
                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Rotation" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="RandomRotLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="RandomRotSlider" Minimum="0" Maximum="10"
                                                    Value="2" TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="RandomRotSlider_Changed"
                                                    Margin="0,0,0,10"/>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Jitter Y" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="RandomYLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="RandomYSlider" Minimum="0" Maximum="20"
                                                    Value="3" TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="RandomYSlider_Changed"
                                                    Margin="0,0,0,2"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="PAPER" Style="{StaticResource SectionLabel}"/>
                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="8" Margin="0,0,0,4">
                                        <StackPanel>
                                            <Border CornerRadius="6" Background="{DynamicResource CardBg}"
                                                    Padding="3" Margin="0,0,0,10">
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Name="PaperLinesBtn" Height="26" Padding="10,0"
                                                            Click="PaperLinesBtn_Click">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="—" FontSize="11"
                                                                       Margin="0,0,4,0"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="Lines" FontSize="10"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Name="PaperDotsBtn" Height="26" Padding="10,0"
                                                            Click="PaperDotsBtn_Click">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="·" FontSize="16"
                                                                       Margin="0,-2,4,0"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="Dots" FontSize="10"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Name="PaperClearBtn" Height="26" Padding="10,0"
                                                            Click="PaperClearBtn_Click">
                                                        <TextBlock Text="Clear" FontSize="10"
                                                                   VerticalAlignment="Center"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>

                                            <StackPanel Name="PaperLinesPanel">
                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Line Spacing" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"/>
                                                    <TextBlock Name="SpacingLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="SpacingSlider" Minimum="20" Maximum="300"
                                                        Value="100" TickFrequency="10"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="SpacingSlider_Changed"
                                                        Margin="0,0,0,10"/>
                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Thickness" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"/>
                                                    <TextBlock Name="ThicknessLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="ThicknessSlider" Minimum="0.5" Maximum="6"
                                                        Value="1" TickFrequency="0.5"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="ThicknessSlider_Changed"
                                                        Margin="0,0,0,4"/>
                                            </StackPanel>

                                            <StackPanel Name="PaperDotsPanel" Visibility="Collapsed">
                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Dot Spacing" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"/>
                                                    <TextBlock Name="DotSpacingLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="DotSpacingSlider" Minimum="10"
                                                        Maximum="100" Value="20" TickFrequency="5"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="DotSpacingSlider_Changed"
                                                        Margin="0,0,0,10"/>
                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Dot Size" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"/>
                                                    <TextBlock Name="DotSizeLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="DotSizeSlider" Minimum="0.5" Maximum="5"
                                                        Value="1.5" TickFrequency="0.5"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="DotSizeSlider_Changed"
                                                        Margin="0,0,0,4"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="PAGE SIZE" Style="{StaticResource SectionLabel}"/>
                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="10,8" Margin="0,0,0,4">
                                        <DockPanel>
                                            <TextBlock Text="Format" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       VerticalAlignment="Center"/>
                                            <ComboBox Name="PaperSizeCombo" Height="28"
                                                      Width="130" HorizontalAlignment="Right"
                                                      DockPanel.Dock="Right"
                                                      FontSize="11"
                                                      SelectionChanged="PaperSizeCombo_Changed">
                                                <ComboBoxItem Content="A4 Portrait"  IsSelected="True"/>
                                                <ComboBoxItem Content="A4 Landscape"/>
                                                <ComboBoxItem Content="A5 Portrait"/>
                                                <ComboBoxItem Content="Letter"/>
                                                <ComboBoxItem Content="Custom…"/>
                                            </ComboBox>
                                        </DockPanel>
                                    </Border>

                                    <!-- Custom resolution — visible only when "Custom…" selected -->
                                    <Border Name="CustomResPanel" Visibility="Collapsed"
                                            Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="10,8" Margin="0,0,0,4">
                                        <StackPanel>
                                            <TextBlock Text="Custom size (px)" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       Margin="0,0,0,6"/>
                                            <DockPanel>
                                                <TextBlock Text="W" FontSize="11" Width="14"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           VerticalAlignment="Center"/>
                                                <TextBox Name="PaperCustomW" Width="80"
                                                         Height="26" FontSize="11"
                                                         Text="794" Margin="4,0,8,0"
                                                         TextChanged="PaperCustomW_Changed"/>
                                                <TextBlock Text="H" FontSize="11" Width="14"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           VerticalAlignment="Center"/>
                                                <TextBox Name="PaperCustomH" Width="80"
                                                         Height="26" FontSize="11"
                                                         Text="1123" Margin="4,0,0,0"
                                                         TextChanged="PaperCustomH_Changed"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- STT -->
                            <Border Grid.Row="2" Padding="10,10"
                                    Background="{DynamicResource Surface2Bg}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <Button Name="SpeechBtn" Height="40" Margin="0,0,0,8"
                                            BorderThickness="0"
                                            Background="{DynamicResource NavActiveBg}"
                                            Click="SpeechBtn_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Name="SpeechBtnIcon" Text="🎤" FontSize="16"
                                                       VerticalAlignment="Center" Margin="0,0,10,0"/>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Voice Input" FontSize="12"
                                                           FontWeight="SemiBold"/>
                                                <TextBlock Name="SttStatusLabel"
                                                           Text="click to record" FontSize="9"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <ComboBox Name="SttDurationCombo" Grid.Column="0"
                                                  Height="28" FontSize="10" Margin="0,0,4,0"
                                                  SelectionChanged="SttDuration_Changed">
                                            <ComboBoxItem Content="3s"/>
                                            <ComboBoxItem Content="5s" IsSelected="True"/>
                                            <ComboBoxItem Content="10s"/>
                                            <ComboBoxItem Content="15s"/>
                                            <ComboBoxItem Content="30s"/>
                                        </ComboBox>
                                        <ComboBox Name="SttLangCombo" Grid.Column="1"
                                                  Height="28" FontSize="10"
                                                  SelectionChanged="SttLang_Changed">
                                            <ComboBoxItem Content="pl" IsSelected="True"/>
                                            <ComboBoxItem Content="en"/>
                                            <ComboBoxItem Content="de"/>
                                            <ComboBoxItem Content="fr"/>
                                            <ComboBoxItem Content="es"/>
                                            <ComboBoxItem Content="it"/>
                                            <ComboBoxItem Content="auto"/>
                                        </ComboBox>
                                    </Grid>
                                </StackPanel>
                            </Border>

                        </Grid>
                    </Border>

                </Grid>
            </Grid>

            <!-- ══ CANVAS AREA ═════════════════════════════════════ -->
            <Grid Grid.Column="1" Background="{DynamicResource AppBg}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="38"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Canvas header -->
                <Border Grid.Row="0"
                        Background="{DynamicResource Surface2Bg}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,0,0,1" Padding="18,0">
                    <DockPanel VerticalAlignment="Center">
                        <TextBlock Name="CenterPanelTitle" Text="ALPHABET EDIT"
                                   FontSize="10" FontWeight="SemiBold"
                                   Foreground="{DynamicResource SecondaryText}"/>
                        <Button Name="PreviewAlphabetBtn" DockPanel.Dock="Right"
                                Height="26" Padding="12,0"
                                Click="PreviewAlphabetButton_Click"
                                ToolTip="Preview all characters">
                            <TextBlock Text="Preview All" FontSize="11"/>
                        </Button>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1">
                    <ScrollViewer Name="AlphabetScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Background="{DynamicResource CanvasBg}">
                        <Grid Name="AlphabetGridHost" Background="{DynamicResource CanvasBg}">
                            <skia:SKElement Name="AlphabetEditCanvas"
                                            PaintSurface="AlphabetEditCanvas_PaintSurface"
                                            IsHitTestVisible="False"/>
                            <Canvas Name="AlphabetInputCanvas" Background="Transparent"
                                    MouseLeftButtonDown="Alphabet_MouseDown"
                                    MouseMove="Alphabet_MouseMove"
                                    MouseLeftButtonUp="Alphabet_MouseUp"
                                    MouseRightButtonDown="Alphabet_MouseRightDown"/>
                        </Grid>
                    </ScrollViewer>
                    <ScrollViewer Name="TypeScrollViewer" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MouseDown="TypeScrollViewer_MouseDown"
                                  MouseMove="TypeScrollViewer_MouseMove"
                                  MouseUp="TypeScrollViewer_MouseUp"
                                  Background="{DynamicResource CanvasBg}">
                        <Grid Name="TypeCanvasHost" Background="{DynamicResource CanvasBg}"
                              VerticalAlignment="Top">
                            <skia:SKElement Name="TypeSkiaCanvas"
                                            PaintSurface="TypeSkia_PaintSurface"
                                            IsHitTestVisible="False"/>
                            <Canvas Name="DisplayCanvas" Background="Transparent"
                                    MouseLeftButtonDown="TypeCanvas_MouseDown"/>
                        </Grid>
                    </ScrollViewer>
                </Grid>
            </Grid>

        </Grid>

        <!-- Hidden compat elements -->
        <Grid Visibility="Collapsed">
            <UniformGrid Name="CharacterGrid" Columns="4"/>
            <TextBlock Name="CurrentCharacterText"/>
            <TextBox Name="CustomCharInput" MaxLength="1"
                     TextChanged="CustomCharInput_TextChanged"/>
            <Button Name="AddCustomCharBtn" Click="AddCustomChar_Click"/>
            <Border Name="DrawOptionsPanel"/>
            <Button Name="DrawOptionsToggleBtn" Click="DrawOptionsToggle_Click"/>
            <Button Name="Var1Btn" Click="VarBtn_Click" Tag="1"/>
            <Button Name="Var2Btn" Click="VarBtn_Click" Tag="2"/>
            <Button Name="Var3Btn" Click="VarBtn_Click" Tag="3"/>
        </Grid>

    </Grid>
</Window>
