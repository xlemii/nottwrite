<Window x:Class="nottwrite.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:skia="clr-namespace:SkiaSharp.Views.WPF;assembly=SkiaSharp.Views.WPF"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="nottwrite"
        Height="900" Width="1400" MinHeight="600" MinWidth="900"
        WindowStyle="None"
        Background="#1E1E1E"
        Icon="pack://application:,,,/icon.png"
        FontFamily="pack://application:,,,/Fonts/geist-font/Geist/ttf/#Geist"
        PreviewKeyDown="Window_PreviewKeyDown" WindowState="Maximized">

    <!-- WindowChrome: frameless + resize support -->
    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="48" ResizeBorderThickness="5"
                            GlassFrameThickness="0" CornerRadius="8"/>
    </shell:WindowChrome.WindowChrome>

    <Window.InputBindings>
        <KeyBinding Key="S" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Save}"/>
        <KeyBinding Key="Z" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Undo}"/>
        <KeyBinding Key="Y" Modifiers="Ctrl" Command="{x:Static ApplicationCommands.Redo}"/>
    </Window.InputBindings>
    <Window.CommandBindings>
        <CommandBinding Command="{x:Static ApplicationCommands.Save}"  Executed="SaveCommand_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Undo}"  Executed="UndoCommand_Executed"/>
        <CommandBinding Command="{x:Static ApplicationCommands.Redo}"  Executed="RedoCommand_Executed"/>
    </Window.CommandBindings>

    <Window.Resources>
        <!-- ═══════════════════════════════════════════════════════
             PALETTE — deep dark + violet accent
             ═══════════════════════════════════════════════════════ -->
        <SolidColorBrush x:Key="AppBg"           Color="#1E1E1E"/>
        <SolidColorBrush x:Key="TitleBarBg"      Color="#202020"/>
        <SolidColorBrush x:Key="PanelBg"         Color="#282828"/>
        <SolidColorBrush x:Key="Surface2Bg"      Color="#242424"/>
        <SolidColorBrush x:Key="CardBg"          Color="#2E2E2E"/>
        <SolidColorBrush x:Key="CardBg2"         Color="#363636"/>
        <SolidColorBrush x:Key="AccentBrush"     Color="#8B7DC4"/>
        <SolidColorBrush x:Key="AccentHover"     Color="#A898D8"/>
        <SolidColorBrush x:Key="NavActiveBg"     Color="#3A3260"/>
        <SolidColorBrush x:Key="ButtonBg"        Color="#2E2E2E"/>
        <SolidColorBrush x:Key="PrimaryText"     Color="#F0F0F0"/>
        <SolidColorBrush x:Key="SecondaryText"   Color="#A0A0A0"/>
        <SolidColorBrush x:Key="AppBorderBrush"  Color="#333333"/>
        <SolidColorBrush x:Key="CanvasBg"        Color="#141414"/>
        <SolidColorBrush x:Key="DangerBrush"     Color="#EF4444"/>
        <SolidColorBrush x:Key="SuccessBrush"    Color="#4ADE80"/>
        <SolidColorBrush x:Key="CharExistsBg"    Color="#162016"/>
        <SolidColorBrush x:Key="CharMissingBg"   Color="#201616"/>
        <SolidColorBrush x:Key="CharExistsFg"    Color="#4ADE80"/>
        <SolidColorBrush x:Key="CharMissingFg"   Color="#F87171"/>
        <SolidColorBrush x:Key="StrokeBrush"     Color="#E8E8E8"/>
        <SolidColorBrush x:Key="LoadedStrokeBrush" Color="#888888"/>
        <SolidColorBrush x:Key="NotebookLineBrush" Color="#2E2E44"/>

        <!-- Context Menu styles -->
        <Style TargetType="ContextMenu">
            <Setter Property="Background"      Value="#252525"/>
            <Setter Property="BorderBrush"     Value="#3A3A3A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="0,5"/>
            <Setter Property="MinWidth"        Value="170"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Border.Effect>
                                <DropShadowEffect Color="#000000" Opacity="0.55"
                                                  BlurRadius="18" ShadowDepth="4" Direction="270"/>
                            </Border.Effect>
                            <StackPanel IsItemsHost="True"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#E8E8E8"/>
            <Setter Property="FontSize"   Value="12.5"/>
            <Setter Property="Padding"    Value="14,8"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="6" Margin="5,1">
                            <ContentPresenter ContentSource="Header"
                                              Margin="{TemplateBinding Padding}"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="#3A3260"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Height"     Value="1"/>
            <Setter Property="Margin"     Value="10,4"/>
            <Setter Property="Background" Value="#3A3A3A"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border Height="{TemplateBinding Height}"
                                Margin="{TemplateBinding Margin}"
                                Background="{TemplateBinding Background}"
                                SnapsToDevicePixels="True"/>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ SECTION LABEL ═══════════════════════════════════ -->
        <Style x:Key="SectionLabel" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{DynamicResource SecondaryText}"/>
            <Setter Property="Margin"     Value="0,0,0,6"/>
        </Style>

        <!-- ═══ DEFAULT BUTTON — hover overlay + scale ══════════ -->
        <Style TargetType="Button">
            <Setter Property="Background"          Value="{DynamicResource ButtonBg}"/>
            <Setter Property="Foreground"          Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"         Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness"     Value="1"/>
            <Setter Property="Padding"             Value="12,0"/>
            <Setter Property="FontSize"            Value="12"/>
            <Setter Property="Cursor"              Value="Hand"/>
            <Setter Property="SnapsToDevicePixels" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform x:Name="BdScale"/>
                            </Border.RenderTransform>
                            <Grid>
                                <!-- HoverLayer fills entire button (not clipped by padding) -->
                                <Border x:Name="HoverLayer" CornerRadius="5"
                                        Background="White" Opacity="0"
                                        IsHitTestVisible="False"/>
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}"
                                                  TextElement.Foreground="{TemplateBinding Foreground}"/>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.07" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.2"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1" Duration="0:0:0.15"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1" Duration="0:0:0.15"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="0.94" Duration="0:0:0.07"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="0.94" Duration="0:0:0.07"/>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.14" Duration="0:0:0.07"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonUp">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleX"
                                            To="1" Duration="0:0:0.14"/>
                                        <DoubleAnimation Storyboard.TargetName="BdScale"
                                            Storyboard.TargetProperty="ScaleY"
                                            To="1" Duration="0:0:0.14"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.35"/>
                            </Trigger>
                            <!-- Keyboard focus ring (accessibility) -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bd" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ NAV BUTTON — Fluent left-accent nav item ════════ -->
        <Style x:Key="NavBtn" TargetType="Button">
            <Setter Property="Background"         Value="Transparent"/>
            <Setter Property="Foreground"         Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"        Value="Transparent"/>
            <Setter Property="BorderThickness"    Value="3,0,0,0"/>
            <Setter Property="Cursor"             Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Height="40">
                            <!-- Left accent bar -->
                            <Border Width="3" HorizontalAlignment="Left"
                                    Background="{TemplateBinding BorderBrush}"
                                    VerticalAlignment="Stretch"/>
                            <!-- Background + hover -->
                            <Border x:Name="Bg" Margin="3,2,6,2" CornerRadius="6"
                                    Background="{TemplateBinding Background}">
                                <Grid>
                                    <Border x:Name="HoverLayer" CornerRadius="5"
                                            Background="White" Opacity="0"
                                            IsHitTestVisible="False"/>
                                    <ContentPresenter HorizontalAlignment="Left"
                                                      VerticalAlignment="Center"
                                                      Margin="12,0"/>
                                </Grid>
                            </Border>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.06" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="HoverLayer"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <!-- Keyboard focus ring (accessibility) -->
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="Bg" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                                <Setter TargetName="Bg" Property="BorderThickness" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ CHROME BUTTON — min/max/close ═══════════════════ -->
        <Style x:Key="ChromeBtn" TargetType="Button">
            <Setter Property="Background"     Value="Transparent"/>
            <Setter Property="Foreground"     Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width"          Value="46"/>
            <Setter Property="Height"         Value="32"/>
            <Setter Property="Cursor"         Value="Hand"/>
            <Setter Property="FontSize"       Value="10"/>
            <Setter Property="shell:WindowChrome.IsHitTestVisibleInChrome" Value="True"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Border x:Name="Overlay" Background="White" Opacity="0" CornerRadius="0"/>
                            <Border x:Name="FocusRing" BorderThickness="2" BorderBrush="Transparent"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocused" Value="True">
                                <Setter TargetName="FocusRing" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Overlay"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.08" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Overlay"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.18"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="Overlay"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.15" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ CLOSE BUTTON ════════════════════════════════════ -->
        <Style x:Key="CloseBtn" TargetType="Button" BasedOn="{StaticResource ChromeBtn}">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid Background="Transparent">
                            <Border x:Name="RedOverlay" Background="#C42B1C"
                                    Opacity="0" CornerRadius="0,8,0,0"/>
                            <Border x:Name="WhiteOverlay" Background="White"
                                    Opacity="0" CornerRadius="0,8,0,0"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RedOverlay"
                                            Storyboard.TargetProperty="Opacity"
                                            To="1" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="RedOverlay"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.18"/>
                                        <DoubleAnimation Storyboard.TargetName="WhiteOverlay"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0" Duration="0:0:0.1"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="PreviewMouseLeftButtonDown">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="WhiteOverlay"
                                            Storyboard.TargetProperty="Opacity"
                                            To="0.2" Duration="0:0:0.05"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TEXTBOX ═════════════════════════════════════════ -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="{DynamicResource CardBg2}"/>
            <Setter Property="Foreground"      Value="{DynamicResource PrimaryText}"/>
            <Setter Property="BorderBrush"     Value="{DynamicResource AppBorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="CaretBrush"      Value="{DynamicResource AccentBrush}"/>
            <Setter Property="SelectionBrush"  Value="{DynamicResource NavActiveBg}"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="TBd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="TBd" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ PROGRESSBAR ═════════════════════════════════════ -->
        <Style TargetType="ProgressBar">
            <Setter Property="Height"          Value="4"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="#333333" CornerRadius="2" ClipToBounds="True">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator" CornerRadius="2"
                                        HorizontalAlignment="Left"
                                        Background="{DynamicResource AccentBrush}"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TEXTBLOCK ═══════════════════════════════════════ -->
        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryText}"/>
        </Style>

        <!-- COMBOBOX / COMBOBOXITEM / SCROLLBAR live in App.xaml (shared) -->

        <!-- ═══ SLIDER ══════════════════════════════════════════ -->
        <Style TargetType="Slider">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Slider">
                        <Border x:Name="SliderFocus" CornerRadius="4" Padding="2,3"
                                BorderThickness="1" BorderBrush="Transparent">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto" MinHeight="{TemplateBinding MinHeight}"/>
                            </Grid.RowDefinitions>
                            <Track Grid.Row="1" x:Name="PART_Track">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Command="Slider.DecreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" CornerRadius="1.5"
                                                        Background="{DynamicResource AccentBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.DecreaseRepeatButton>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Command="Slider.IncreaseLarge">
                                        <RepeatButton.Template>
                                            <ControlTemplate TargetType="RepeatButton">
                                                <Border Height="3" CornerRadius="1.5"
                                                        Background="{DynamicResource AppBorderBrush}"/>
                                            </ControlTemplate>
                                        </RepeatButton.Template>
                                    </RepeatButton>
                                </Track.IncreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Ellipse Width="14" Height="14"
                                                         Fill="{DynamicResource AccentBrush}"
                                                         Stroke="{DynamicResource CanvasBg}" StrokeThickness="2">
                                                    <Ellipse.Effect>
                                                        <DropShadowEffect Color="#8B7DC4"
                                                            BlurRadius="6" ShadowDepth="0"
                                                            Opacity="0.5"/>
                                                    </Ellipse.Effect>
                                                </Ellipse>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="SliderFocus" Property="BorderBrush"
                                        Value="{DynamicResource AccentBrush}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ═══ TOGGLE OFF STYLE ════════════════════════════════ -->
        <Style x:Key="ToggleOffBtn" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background"   Value="{DynamicResource CardBg2}"/>
            <Setter Property="FontSize"     Value="10"/>
            <Setter Property="FontWeight"   Value="Bold"/>
            <Setter Property="Padding"      Value="6,2"/>
            <Setter Property="BorderBrush"  Value="{DynamicResource AppBorderBrush}"/>
        </Style>

    </Window.Resources>

    <!-- ═══════════════════════════════════════════════════════════
         ROOT GRID
         ═══════════════════════════════════════════════════════════ -->
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>   <!-- Title bar -->
            <RowDefinition Height="*"/>    <!-- Content -->
        </Grid.RowDefinitions>

        <!-- hidden compat elements -->
        <skia:SKElement Name="SkiaCanvas" Width="0" Height="0" Visibility="Collapsed"
                        PaintSurface="SkiaCanvas_PaintSurface"/>
        <Canvas Name="InputCanvas" Width="0" Height="0" Visibility="Collapsed"/>

        <!-- ╔══════════════════════════════════════════════════════╗
             ║  CUSTOM TITLE BAR                                   ║
             ╚══════════════════════════════════════════════════════╝ -->
        <Grid Grid.Row="0" Background="{DynamicResource TitleBarBg}"
              MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Left: Brand + Template controls -->
            <StackPanel Grid.Column="0" Orientation="Horizontal"
                        VerticalAlignment="Center" Margin="14,0,0,0">

                <!-- App name + one-line identity -->
                <TextBlock Text="nottwrite" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryText}"
                           VerticalAlignment="Center" Margin="0,0,6,0"/>
                <!-- unsaved-changes dot -->
                <Ellipse Name="TitleUnsavedDot" Width="7" Height="7" Margin="0,0,10,0"
                         VerticalAlignment="Center" Visibility="Collapsed"
                         Fill="{DynamicResource WarningBrush}"
                         ToolTip="Unsaved changes"/>
                <Border Width="1" Height="14" Background="{DynamicResource AppBorderBrush}"
                        VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBlock Text="handwriting → font &amp; notes" FontSize="11"
                           Foreground="{DynamicResource SecondaryText}"
                           VerticalAlignment="Center" Margin="0,0,20,0"/>
            </StackPanel>

            <!-- Right: Save As + Chrome buttons -->
            <StackPanel Grid.Column="2" Orientation="Horizontal"
                        VerticalAlignment="Center">
                <!-- Save As -->
                <Grid Margin="0,0,10,0"
                      shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Name="ExportMenuBtn" Height="30" Padding="12,0"
                            BorderThickness="0" Click="ExportMenuBtn_Click"
                            AutomationProperties.Name="Export"
                            Background="{DynamicResource AccentBrush}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            Foreground="White"><!-- primary action: solid accent, theme-aware -->
                        <Button.Effect>
                            <DropShadowEffect Color="#000000" Opacity="0.28"
                                              BlurRadius="8" ShadowDepth="2" Direction="270"/>
                        </Button.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE74E;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="12" Foreground="White"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Export" FontSize="12" FontWeight="SemiBold"
                                       Foreground="White" VerticalAlignment="Center"/>
                            <Border Width="1" Height="14" Margin="9,0,8,0"
                                    Background="#FFFFFF" Opacity="0.30"/>
                            <TextBlock Text="&#xE70D;" FontFamily="Segoe MDL2 Assets"
                                       FontSize="9" Foreground="White" Opacity="0.9"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Popup Name="ExportPopup"
                           PlacementTarget="{Binding ElementName=ExportMenuBtn}"
                           Placement="Bottom" StaysOpen="False"
                           AllowsTransparency="True" VerticalOffset="4">
                        <Border Background="{DynamicResource CardBg}"
                                BorderBrush="{DynamicResource AppBorderBrush}"
                                BorderThickness="1" CornerRadius="10"
                                Padding="6" MinWidth="184">
                            <Border.Effect>
                                <DropShadowEffect Color="#000" BlurRadius="28"
                                                  ShadowDepth="6" Opacity="0.6"/>
                            </Border.Effect>
                            <StackPanel>
                                <!-- Font export — shown in Edit mode (the primary result there) -->
                                <StackPanel Name="FontExportSection" Visibility="Collapsed">
                                    <TextBlock Text="FONT" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryText}"
                                               Margin="10,6,10,6"/>
                                    <Button Style="{StaticResource PopupItemBtn}"
                                            Click="ExportFontFromMenu_Click">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <Border Width="24" Height="24" CornerRadius="5"
                                                    Background="#2A2350" Margin="0,0,10,0">
                                                <TextBlock Text="&#x2B07;" FontSize="12"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="Font (.ttf)" FontSize="12.5"
                                                           VerticalAlignment="Center"/>
                                                <TextBlock Text="installable handwriting font" FontSize="10"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Button>
                                    <Border Height="1" Margin="8,6"
                                            Background="{DynamicResource AppBorderBrush}"/>
                                </StackPanel>

                                <TextBlock Text="EXPORT PAGE AS" FontSize="11" FontWeight="SemiBold"
                                           Foreground="{DynamicResource SecondaryText}"
                                           Margin="10,6,10,6"/>
                                <Button Style="{StaticResource PopupItemBtn}"
                                        Click="ExportPngButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="24" Height="24" CornerRadius="5"
                                                Background="#1E3A5F" Margin="0,0,10,0">
                                            <TextBlock Text="P" FontSize="11" FontWeight="Bold"
                                                       Foreground="#60A5FA"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="PNG image" FontSize="12.5"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PopupItemBtn}"
                                        Click="ExportJpgButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="24" Height="24" CornerRadius="5"
                                                Background="#3B1F1F" Margin="0,0,10,0">
                                            <TextBlock Text="J" FontSize="11" FontWeight="Bold"
                                                       Foreground="#F87171"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="JPG image" FontSize="12.5"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PopupItemBtn}"
                                        Click="ExportPdfButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="24" Height="24" CornerRadius="5"
                                                Background="#3B2020" Margin="0,0,10,0">
                                            <TextBlock Text="&#x1F4C4;" FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="PDF document" FontSize="12.5"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource PopupItemBtn}"
                                        Click="ExportSvgButton_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Border Width="24" Height="24" CornerRadius="5"
                                                Background="#1F3B2A" Margin="0,0,10,0">
                                            <TextBlock Text="&#x2B21;" FontSize="12"
                                                       Foreground="#5BD08A"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <TextBlock Text="SVG vector" FontSize="12.5"
                                                   VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <!-- Divider -->
                <Rectangle Width="1" Height="22" Fill="{DynamicResource AppBorderBrush}"
                           Margin="0,0,0,0"/>

                <!-- Window chrome buttons -->
                <Button Style="{StaticResource ChromeBtn}"
                        Click="BtnSettings_Click"
                        ToolTip="Settings"
                        AutomationProperties.Name="Settings"
                        shell:WindowChrome.IsHitTestVisibleInChrome="True">
                    <TextBlock Text="&#x2699;" FontSize="12"
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>

                <Button Style="{StaticResource ChromeBtn}"
                        Click="BtnMinimize_Click"
                        ToolTip="Minimise"
                        AutomationProperties.Name="Minimise">
                    <TextBlock Text="&#x268A;" FontSize="11"
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource ChromeBtn}"
                        Click="BtnMaximize_Click"
                        ToolTip="Maximise / Restore"
                        AutomationProperties.Name="Maximise or restore">
                    <TextBlock Text="&#x2750;" FontSize="9"
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
                <Button Style="{StaticResource CloseBtn}"
                        Click="BtnClose_Click"
                        ToolTip="Close"
                        AutomationProperties.Name="Close window">
                    <TextBlock Text="&#x2715;" FontSize="10"
                               Foreground="{DynamicResource PrimaryText}"
                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- ╔══════════════════════════════════════════════════════╗
             ║  MAIN CONTENT                                       ║
             ╚══════════════════════════════════════════════════════╝ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="265"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ══ LEFT SIDEBAR ════════════════════════════════════ -->
            <Grid Grid.Column="0" Background="{DynamicResource PanelBg}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>  <!-- Mode nav -->
                    <RowDefinition Height="*"/>     <!-- Settings -->
                </Grid.RowDefinitions>

                <!-- Mode Navigation -->
                <Border Grid.Row="0"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,0,0,1" Padding="0,6,0,6">
                    <StackPanel>
                        <Button Name="NotesModeBtn"
                                Style="{StaticResource NavBtn}"
                                Click="NotesModeBtn_Click"
                                AutomationProperties.Name="Notes — personal library"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x1F4D3;" FontSize="14" Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Notes" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="personal library" FontSize="11"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Name="TypeModeBtn"
                                Style="{StaticResource NavBtn}"
                                Click="TypeModeBtn_Click"
                                AutomationProperties.Name="Type — write on paper"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x270D;" FontSize="15" Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Type" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Text="write on paper" FontSize="11"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Name="EditModeBtn"
                                Style="{StaticResource NavBtn}"
                                Click="EditModeBtn_Click"
                                AutomationProperties.Name="Edit — draw characters"
                                shell:WindowChrome.IsHitTestVisibleInChrome="True">
                            <DockPanel VerticalAlignment="Center">
                                <TextBlock Text="&#x270F;" FontSize="15" Margin="0,0,12,0"
                                           DockPanel.Dock="Left" VerticalAlignment="Center"/>
                                <Border Name="EditCountBadge" DockPanel.Dock="Right"
                                        VerticalAlignment="Center" Margin="6,0,2,0"
                                        CornerRadius="9" Padding="7,2"
                                        Background="{DynamicResource Surface2Bg}">
                                    <TextBlock Name="EditCountText" Text="0/0" FontSize="10.5"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AccentBrush}"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Edit" FontSize="13" FontWeight="SemiBold"/>
                                    <TextBlock Name="EditNavSubtitle" Text="draw characters" FontSize="11"
                                               Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </DockPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <!-- Settings panels (Edit / Type) -->
                <Grid Grid.Row="1">

                    <!-- ── NOTES FOLDERS ──────────────────────────── -->
                    <Border Name="NotesLeftPanel" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <DockPanel Grid.Row="0" Margin="16,14,10,8">
                                <Button DockPanel.Dock="Right" Click="NewFolder_Click"
                                        Width="22" Height="22" Padding="0"
                                        Background="Transparent" BorderThickness="0"
                                        ToolTip="New category"
                                        AutomationProperties.Name="New category">
                                    <TextBlock Text="+" FontSize="17" FontWeight="Light"
                                               Foreground="{DynamicResource AccentBrush}"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               Margin="0,-2,0,0"/>
                                </Button>
                                <TextBlock Text="LIBRARY" Style="{StaticResource SectionLabel}"
                                           Margin="0" VerticalAlignment="Center"/>
                            </DockPanel>
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel Name="FolderListPanel" Margin="8,0,8,8"/>
                            </ScrollViewer>
                        </Grid>
                    </Border>

                    <!-- ── EDIT SETTINGS ──────────────────────────── -->
                    <Border Name="EditLeftPanel">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <!-- Toolbar -->
                            <Border Grid.Row="0" Padding="10,8"
                                    Background="{DynamicResource Surface2Bg}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <StackPanel>
                                    <TextBlock Name="EditActiveCharLabel" Visibility="Collapsed"/>
                                    <WrapPanel>
                                        <Button Name="GhostToggleBtn" Height="28" Padding="8,0"
                                                Margin="0,0,3,3"
                                                ToolTip="Ghost — faint reference letter" Click="GhostToggle_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x1F441;" FontSize="11"
                                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Ghost" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Name="GuidesToggleBtn" Height="28" Padding="8,0"
                                                Margin="0,0,3,3"
                                                ToolTip="Guides — baseline / x-height / cap lines"
                                                AutomationProperties.Name="Toggle proportion guides"
                                                Click="GuidesToggle_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x2261;" FontSize="13"
                                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Guides" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Name="FocusModeBtn" Height="28" Padding="8,0"
                                                Margin="0,0,3,3"
                                                ToolTip="Focus mode — edit the selected glyph on the full canvas"
                                                AutomationProperties.Name="Toggle single-glyph focus mode"
                                                Click="FocusModeToggle_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x26F6;" FontSize="12"
                                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Focus" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Button Height="28" Padding="8,0" Margin="0,0,3,3"
                                                ToolTip="Undo" AutomationProperties.Name="Undo"
                                                Click="UndoButton_Click">
                                            <TextBlock Text="&#x21A9;" FontSize="13"/>
                                        </Button>
                                        <Button Height="28" Padding="8,0" Margin="0,0,3,3"
                                                ToolTip="Redo" AutomationProperties.Name="Redo"
                                                Click="RedoButton_Click">
                                            <TextBlock Text="&#x21AA;" FontSize="13"/>
                                        </Button>
                                        <Button Height="28" Padding="8,0" Margin="0,0,3,3"
                                                ToolTip="Clear" Click="ClearButton_Click">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#x2715;" FontSize="10" FontWeight="Bold"
                                                           Foreground="{DynamicResource DangerBrush}"
                                                           Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                <TextBlock Text="Clear" FontSize="11" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>
                                        <Border Name="EditCharColorSwatch" Visibility="Collapsed"
                                                Width="0" Height="0"
                                                MouseLeftButtonDown="EditCharColorSwatch_Click"/>
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- Scrollable settings -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          Background="Transparent"
                                          ClipToBounds="True">
                                <StackPanel Margin="10,10,10,10">

                                    <TextBlock Text="TEMPLATE" Style="{StaticResource SectionLabel}"/>
                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="8" Margin="0,0,0,10">
                                        <StackPanel>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Height="28" Margin="0,0,3,0"
                                                        ToolTip="Export this template as an installable .ttf font"
                                                        Click="ExportFontButton_Click">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="&#x2191;" FontSize="12" FontWeight="Bold"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBlock Text="Export .ttf" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Height="28" Margin="3,0,0,0"
                                                        ToolTip="Import a .ttf font or .nwt bundle as an editable template"
                                                        Click="ImportTemplate_Click">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="&#x2193;" FontSize="12" FontWeight="Bold"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                        <TextBlock Text="Import" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                            <Grid Margin="0,0,0,6">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Height="28" Margin="0,0,3,0"
                                                        ToolTip="Print a sheet, write each letter by hand, then photograph it"
                                                        Click="ExportTemplateSheet_Click">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="&#x1F5A8;" FontSize="11"
                                                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="Sheet" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Grid.Column="1" Height="28" Margin="3,0,0,0"
                                                        ToolTip="Import letters from a photo/scan of a filled-in sheet (experimental, needs Python)"
                                                        Click="ImportScan_Click">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="&#x1F4F7;" FontSize="11"
                                                                   VerticalAlignment="Center" Margin="0,0,5,0"/>
                                                        <TextBlock Text="Scan" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                            </Grid>
                                            <ComboBox Name="TemplateComboBox" Height="30"
                                                      SelectionChanged="TemplateComboBox_SelectionChanged"/>
                                            <Grid Margin="0,6,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="*"/>
                                                </Grid.ColumnDefinitions>
                                                <Button Grid.Column="0" Height="28" Margin="0,0,3,0"
                                                        ToolTip="New template" Click="NewTemplate_Click">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="+" FontSize="15" FontWeight="Light"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   VerticalAlignment="Center" Margin="0,-2,4,0"/>
                                                        <TextBlock Text="New" FontSize="11" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Name="SetDefaultTemplateBtn" Grid.Column="1" Height="28"
                                                        Margin="3,0,3,0" Padding="0" ToolTip="Set as default"
                                                        AutomationProperties.Name="Set template as default"
                                                        Click="SetDefaultTemplate_Click">
                                                    <TextBlock Name="DefaultStarLabel" Text="&#x2606;" FontSize="14"
                                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Button>
                                                <Button Grid.Column="2" Height="28" Margin="3,0,0,0" Padding="0"
                                                        ToolTip="Delete template"
                                                        AutomationProperties.Name="Delete template"
                                                        Click="DeleteTemplate_Click">
                                                    <TextBlock Text="&#x2715;" FontSize="11" FontWeight="Bold"
                                                               Foreground="{DynamicResource DangerBrush}"
                                                               VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Button>
                                            </Grid>

                                            <!-- Live font preview (pangram, current glyphs) -->
                                            <Border CornerRadius="6" Height="56" Margin="0,8,0,0"
                                                    Background="{DynamicResource CanvasBg}"
                                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                                    BorderThickness="1"
                                                    ToolTip="Live preview of your font — updates as you draw">
                                                <skia:SKElement Name="FontPreviewCanvas"
                                                                PaintSurface="FontPreviewCanvas_PaintSurface"/>
                                            </Border>

                                            <!-- Custom preview text -->
                                            <TextBox Name="PreviewTextBox" Height="26" Margin="0,6,0,0"
                                                     FontSize="11" Text="The quick brown fox"
                                                     ToolTip="Type your own text to preview your font"
                                                     TextChanged="PreviewTextBox_Changed"/>

                                            <!-- Character set settings -->
                                            <Grid Margin="0,8,0,0">
                                                <Button Name="CharSetBtn" Height="28" Click="CharSetBtn_Click"
                                                        HorizontalContentAlignment="Left" Padding="9,0"
                                                        ToolTip="Choose which characters your font includes">
                                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                        <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets"
                                                                   FontSize="11" Foreground="{DynamicResource AccentBrush}"
                                                                   VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                        <TextBlock Text="Character set" FontSize="10.5"
                                                                   VerticalAlignment="Center"/>
                                                        <TextBlock Name="CharSetCount" Text="" FontSize="9.5"
                                                                   Foreground="{DynamicResource SecondaryText}"
                                                                   VerticalAlignment="Center" Margin="6,0,0,0"/>
                                                    </StackPanel>
                                                </Button>
                                                <Popup Name="CharSetPopup" PlacementTarget="{Binding ElementName=CharSetBtn}"
                                                       Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                                                       VerticalOffset="4">
                                                    <Border Background="{DynamicResource CardBg}"
                                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                                            BorderThickness="1" CornerRadius="10" Padding="6" MinWidth="248">
                                                        <Border.Effect>
                                                            <DropShadowEffect Color="#000" BlurRadius="26" ShadowDepth="6" Opacity="0.55"/>
                                                        </Border.Effect>
                                                        <StackPanel>
                                                            <TextBlock Text="CHARACTERS IN YOUR FONT" FontSize="11" FontWeight="SemiBold"
                                                                       Foreground="{DynamicResource SecondaryText}" Margin="8,5,8,7"/>
                                                            <StackPanel Name="CharCatPanel"/>
                                                        </StackPanel>
                                                    </Border>
                                                </Popup>
                                            </Grid>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="BRUSH" Style="{StaticResource SectionLabel}"/>

                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="8" Margin="0,0,0,12">
                                        <StackPanel>
                                            <UniformGrid Columns="3" Rows="2">
                                                <Button Name="BrushRoundBtn" Height="52" Margin="2"
                                                        Tag="Round" Click="BrushShape_Click" ToolTip="Round — even, soft tip">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="&#x25CF;" FontSize="15" TextAlignment="Center"/>
                                                        <TextBlock Text="Round" FontSize="10.5" TextAlignment="Center"
                                                                   Margin="0,3,0,0" Opacity="0.85"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Name="BrushFlatBtn" Height="52" Margin="2"
                                                        Tag="Flat" Click="BrushShape_Click" ToolTip="Flat — thin marker edge">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="&#x25AC;" FontSize="15" TextAlignment="Center"/>
                                                        <TextBlock Text="Flat" FontSize="10.5" TextAlignment="Center"
                                                                   Margin="0,3,0,0" Opacity="0.85"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Name="BrushCalligBtn" Height="52" Margin="2"
                                                        Tag="Calligraphy" Click="BrushShape_Click" ToolTip="Calligraphy — angled nib">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="&#x2712;" FontSize="15" TextAlignment="Center"/>
                                                        <TextBlock Text="Callig." FontSize="10.5" TextAlignment="Center"
                                                                   Margin="0,3,0,0" Opacity="0.85"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Name="BrushTriangleBtn" Height="52" Margin="2"
                                                        Tag="Triangle" Click="BrushShape_Click" ToolTip="Triangle — tapered to a point">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="&#x25B2;" FontSize="13" TextAlignment="Center"/>
                                                        <TextBlock Text="Triangle" FontSize="10.5" TextAlignment="Center"
                                                                   Margin="0,3,0,0" Opacity="0.85"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Name="BrushInkBtn" Height="52" Margin="2"
                                                        Tag="Ink" Click="BrushShape_Click" ToolTip="Ink — pressure-like variation">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="&#x1F58B;" FontSize="14" TextAlignment="Center"/>
                                                        <TextBlock Text="Ink" FontSize="10.5" TextAlignment="Center"
                                                                   Margin="0,3,0,0" Opacity="0.85"/>
                                                    </StackPanel>
                                                </Button>
                                                <Button Name="BrushChiselBtn" Height="52" Margin="2"
                                                        Tag="Chisel" Click="BrushShape_Click" ToolTip="Chisel — fixed 45° edge">
                                                    <StackPanel VerticalAlignment="Center">
                                                        <TextBlock Text="&#x2571;" FontSize="15" TextAlignment="Center"/>
                                                        <TextBlock Text="Chisel" FontSize="10.5" TextAlignment="Center"
                                                                   Margin="0,3,0,0" Opacity="0.85"/>
                                                    </StackPanel>
                                                </Button>
                                            </UniformGrid>

                                            <Border Height="1" Margin="2,8,2,8"
                                                    Background="{DynamicResource AppBorderBrush}"/>

                                            <Button Name="EraserBtn" Height="32" Margin="2,0"
                                                    ToolTip="Eraser (E)" Click="EraserBtn_Click">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Text="&#x232B;" FontSize="14"
                                                               VerticalAlignment="Center" Margin="0,0,7,0"/>
                                                    <TextBlock Text="Eraser" FontSize="11"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </StackPanel>
                                    </Border>

                                    <!-- Brush preview -->
                                    <Border CornerRadius="8" Height="48"
                                            Background="{DynamicResource CanvasBg}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1" Margin="0,0,0,12">
                                        <skia:SKElement Name="BrushPreviewCanvas"
                                                        PaintSurface="BrushPreviewCanvas_PaintSurface"/>
                                    </Border>

                                    <TextBlock Text="BRUSH SETTINGS" Style="{StaticResource SectionLabel}"/>

                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="12,12" Margin="0,0,0,4">
                                        <StackPanel>
                                            <!-- ── Basic: Size + Opacity (always visible) ── -->
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Size" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="BrushSizeLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="BrushSizeSlider" Minimum="1" Maximum="24"
                                                    Value="3.5" TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="BrushSizeSlider_Changed"
                                                    Margin="0,0,0,10"/>

                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Opacity" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="BrushOpacityLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="BrushOpacitySlider" Minimum="10"
                                                    Maximum="100" Value="100" TickFrequency="5"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="BrushOpacity_Changed"
                                                    Margin="0,0,0,4"/>

                                            <!-- ── Advanced toggle ── -->
                                            <Button Name="AdvancedBrushToggleBtn" Height="26"
                                                    Margin="0,4,0,0" Padding="2,0"
                                                    HorizontalContentAlignment="Left"
                                                    Background="Transparent" BorderThickness="0"
                                                    Click="AdvancedBrushToggle_Click"
                                                    ToolTip="Show taper, smoothing, pressure and more">
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <TextBlock Name="AdvancedBrushChevron" Text="&#x25B8;"
                                                               FontSize="10" Margin="0,0,7,0"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               VerticalAlignment="Center"/>
                                                    <TextBlock Name="AdvancedBrushLabel" Text="More options"
                                                               FontSize="11" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>

                                            <!-- ── Advanced: collapsed by default ── -->
                                            <StackPanel Name="AdvancedBrushPanel" Visibility="Collapsed"
                                                        Margin="0,8,0,0">
                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Taper" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"
                                                               VerticalAlignment="Center"/>
                                                    <Button Name="TaperToggleBtn" Width="42" Height="20"
                                                            DockPanel.Dock="Right" Margin="4,0,0,0"
                                                            Style="{StaticResource ToggleOffBtn}"
                                                            Click="TaperToggle_Click">
                                                        <TextBlock Name="TaperToggleLabel" Text="OFF"
                                                                   FontSize="10" FontWeight="Bold"/>
                                                    </Button>
                                                    <TextBlock Name="TaperValueLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="TaperSlider" Minimum="0" Maximum="10"
                                                        Value="0" TickFrequency="0.5"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="TaperSlider_Changed"
                                                        Margin="0,0,0,10"/>

                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Tip Roundness" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"/>
                                                    <TextBlock Name="TipRoundnessLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="TipRoundnessSlider" Minimum="0" Maximum="1"
                                                        Value="1" TickFrequency="0.05"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="TipRoundness_Changed"
                                                        Margin="0,0,0,10"/>

                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Smoothing" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"/>
                                                    <TextBlock Name="BrushSmoothLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="BrushSmoothSlider" Minimum="0" Maximum="5"
                                                        Value="2" TickFrequency="1"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="BrushSmooth_Changed"
                                                        Margin="0,0,0,10"/>

                                                <StackPanel Name="CalligAnglePanel" Visibility="Collapsed">
                                                    <DockPanel Margin="0,0,0,3">
                                                        <TextBlock Text="Callig Angle" FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryText}"/>
                                                        <TextBlock Name="CalligAngleLabel" FontSize="11"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   HorizontalAlignment="Right"
                                                                   DockPanel.Dock="Right"/>
                                                    </DockPanel>
                                                    <Slider Name="CalligAngleSlider" Minimum="0"
                                                            Maximum="90" Value="45" TickFrequency="5"
                                                            IsSnapToTickEnabled="True"
                                                            ValueChanged="CalligAngle_Changed"
                                                            Margin="0,0,0,10"/>
                                                </StackPanel>

                                                <DockPanel>
                                                    <TextBlock Text="Pressure" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"
                                                               VerticalAlignment="Center"/>
                                                    <Button Name="PressureToggleBtn" Width="42" Height="20"
                                                            DockPanel.Dock="Right"
                                                            Style="{StaticResource ToggleOffBtn}"
                                                            Click="PressureToggle_Click">
                                                        <TextBlock Name="PressureToggleLabel" Text="OFF"
                                                                   FontSize="10" FontWeight="Bold"/>
                                                    </Button>
                                                </DockPanel>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                            <!-- Char colour — opens the shared colour picker (ColorPickerWindow) -->
                            <Border Grid.Row="2" Padding="10,10"
                                    Background="{DynamicResource Surface2Bg}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,1,0,0">
                                <Button Name="EditCharColorBtn" Height="38"
                                        Click="EditCharColor_Click"
                                        HorizontalContentAlignment="Stretch"
                                        AutomationProperties.Name="Character ink colour"
                                        ToolTip="Set the ink colour for this character">
                                    <DockPanel LastChildFill="False">
                                        <TextBlock Text="CHAR COLOR" Style="{StaticResource SectionLabel}"
                                                   Margin="0" DockPanel.Dock="Left"
                                                   VerticalAlignment="Center"/>
                                        <Border Name="InlineColorPreview" Width="44" Height="18"
                                                CornerRadius="4" Background="#E8E8E8"
                                                BorderBrush="{DynamicResource AppBorderBrush}"
                                                BorderThickness="1"
                                                DockPanel.Dock="Right" VerticalAlignment="Center"/>
                                    </DockPanel>
                                </Button>
                            </Border>

                            <!-- Progress -->
                            <Border Grid.Row="3" Padding="12,8"
                                    Background="{DynamicResource Surface2Bg}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,1,0,0">
                                <StackPanel>
                                    <DockPanel Margin="0,0,0,5">
                                        <TextBlock Text="Progress" FontSize="11"
                                                   Foreground="{DynamicResource SecondaryText}"/>
                                        <TextBlock Name="AlphabetProgressText" FontSize="11"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Right" DockPanel.Dock="Right"/>
                                    </DockPanel>
                                    <ProgressBar Name="AlphabetProgressBar" Maximum="100"/>
                                </StackPanel>
                            </Border>
                                </StackPanel>
                            </ScrollViewer>

                        </Grid>
                    </Border>

                    <!-- ── TYPE SETTINGS ──────────────────────────── -->
                    <Border Name="TypeLeftPanel" Visibility="Collapsed">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <Border Grid.Row="0" Padding="10,8"
                                    Background="{DynamicResource Surface2Bg}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="0,0,0,1">
                                <DockPanel>
                                    <TextBlock Text="STYLE" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryText}"
                                               VerticalAlignment="Center"/>
                                    <!-- TypeColorSwatch hidden — used only as binding source for toolbar -->
                                    <Border Name="TypeColorSwatch" Visibility="Collapsed"
                                            Background="#E8E8E8"/>
                                    <!-- B/I moved to the formatting toolbar above the canvas -->
                                </DockPanel>
                            </Border>

                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                          Padding="10,10,10,10"
                                          ClipToBounds="True">
                                <StackPanel>

                                    <TextBlock Text="TYPOGRAPHY" Style="{StaticResource SectionLabel}"/>
                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Font Size" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="FontSizeLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="FontSizeSlider" Minimum="40" Maximum="400"
                                                    Value="180" TickFrequency="10"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="FontSizeSlider_Changed"
                                                    Margin="0,0,0,10"/>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Letter Spacing" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="LetterSpacingLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="LetterSpacingSlider" Minimum="-20"
                                                    Maximum="80" Value="0" TickFrequency="2"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="LetterSpacingSlider_Changed"
                                                    Margin="0,0,0,10"/>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Word Spacing" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="WordSpacingLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="WordSpacingSlider" Minimum="-20"
                                                    Maximum="120" Value="0" TickFrequency="4"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="WordSpacingSlider_Changed"
                                                    Margin="0,0,0,10"/>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Line Height" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="LineHeightLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="LineHeightSlider" Minimum="0.8"
                                                    Maximum="4.0" Value="1.6" TickFrequency="0.1"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="LineHeightSlider_Changed"
                                                    Margin="0,0,0,10"/>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Stroke Width" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="GenStrokeWidthLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="GenStrokeWidthSlider" Minimum="0.5"
                                                    Maximum="10" Value="3.5" TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="GenStrokeWidthSlider_Changed"
                                                    Margin="0,0,0,2"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="NATURAL FEEL" Style="{StaticResource SectionLabel}"/>
                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="12,10" Margin="0,0,0,10">
                                        <StackPanel>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Rotation" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="RandomRotLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="RandomRotSlider" Minimum="0" Maximum="10"
                                                    Value="2" TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="RandomRotSlider_Changed"
                                                    Margin="0,0,0,10"/>
                                            <DockPanel Margin="0,0,0,3">
                                                <TextBlock Text="Jitter Y" FontSize="11"
                                                           Foreground="{DynamicResource SecondaryText}"/>
                                                <TextBlock Name="RandomYLabel" FontSize="11"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentBrush}"
                                                           HorizontalAlignment="Right"
                                                           DockPanel.Dock="Right"/>
                                            </DockPanel>
                                            <Slider Name="RandomYSlider" Minimum="0" Maximum="20"
                                                    Value="3" TickFrequency="0.5"
                                                    IsSnapToTickEnabled="True"
                                                    ValueChanged="RandomYSlider_Changed"
                                                    Margin="0,0,0,2"/>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="PAPER" Style="{StaticResource SectionLabel}"/>
                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="8" Margin="0,0,0,4">
                                        <StackPanel>
                                            <Border CornerRadius="6" Background="{DynamicResource CardBg}"
                                                    Padding="3" Margin="0,0,0,10">
                                                <StackPanel Orientation="Horizontal">
                                                    <Button Name="PaperLinesBtn" Height="26" Padding="10,0"
                                                            Click="PaperLinesBtn_Click">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="—" FontSize="11"
                                                                       Margin="0,0,4,0"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="Lines" FontSize="11"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Name="PaperDotsBtn" Height="26" Padding="10,0"
                                                            Click="PaperDotsBtn_Click">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="·" FontSize="16"
                                                                       Margin="0,-2,4,0"
                                                                       Foreground="{DynamicResource AccentBrush}"
                                                                       VerticalAlignment="Center"/>
                                                            <TextBlock Text="Dots" FontSize="11"
                                                                       VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Name="PaperClearBtn" Height="26" Padding="10,0"
                                                            Click="PaperClearBtn_Click">
                                                        <TextBlock Text="Clear" FontSize="11"
                                                                   VerticalAlignment="Center"/>
                                                    </Button>
                                                </StackPanel>
                                            </Border>

                                            <StackPanel Name="PaperLinesPanel">
                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Line Spacing" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"/>
                                                    <TextBlock Name="SpacingLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="SpacingSlider" Minimum="20" Maximum="300"
                                                        Value="100" TickFrequency="10"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="SpacingSlider_Changed"
                                                        Margin="0,0,0,10"/>
                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Thickness" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"/>
                                                    <TextBlock Name="ThicknessLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="ThicknessSlider" Minimum="0.5" Maximum="6"
                                                        Value="1" TickFrequency="0.5"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="ThicknessSlider_Changed"
                                                        Margin="0,0,0,4"/>
                                            </StackPanel>

                                            <StackPanel Name="PaperDotsPanel" Visibility="Collapsed">
                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Dot Spacing" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"/>
                                                    <TextBlock Name="DotSpacingLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="DotSpacingSlider" Minimum="10"
                                                        Maximum="100" Value="20" TickFrequency="5"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="DotSpacingSlider_Changed"
                                                        Margin="0,0,0,10"/>
                                                <DockPanel Margin="0,0,0,3">
                                                    <TextBlock Text="Dot Size" FontSize="11"
                                                               Foreground="{DynamicResource SecondaryText}"/>
                                                    <TextBlock Name="DotSizeLabel" FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               DockPanel.Dock="Right"/>
                                                </DockPanel>
                                                <Slider Name="DotSizeSlider" Minimum="0.5" Maximum="5"
                                                        Value="1.5" TickFrequency="0.5"
                                                        IsSnapToTickEnabled="True"
                                                        ValueChanged="DotSizeSlider_Changed"
                                                        Margin="0,0,0,4"/>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="PAGE SIZE" Style="{StaticResource SectionLabel}"/>
                                    <Border Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="10,8" Margin="0,0,0,4">
                                        <DockPanel>
                                            <TextBlock Text="Format" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       VerticalAlignment="Center"/>
                                            <ComboBox Name="PaperSizeCombo" Height="28"
                                                      Width="130" HorizontalAlignment="Right"
                                                      DockPanel.Dock="Right"
                                                      FontSize="11"
                                                      SelectionChanged="PaperSizeCombo_Changed">
                                                <ComboBoxItem Content="A4 Portrait"  IsSelected="True"/>
                                                <ComboBoxItem Content="A4 Landscape"/>
                                                <ComboBoxItem Content="A5 Portrait"/>
                                                <ComboBoxItem Content="Letter"/>
                                                <ComboBoxItem Content="Custom…"/>
                                            </ComboBox>
                                        </DockPanel>
                                    </Border>

                                    <!-- Custom resolution — visible only when "Custom…" selected -->
                                    <Border Name="CustomResPanel" Visibility="Collapsed"
                                            Background="{DynamicResource Surface2Bg}"
                                            CornerRadius="8" Padding="10,8" Margin="0,0,0,4">
                                        <StackPanel>
                                            <TextBlock Text="Custom size (px)" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       Margin="0,0,0,6"/>
                                            <DockPanel>
                                                <TextBlock Text="W" FontSize="11" Width="14"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           VerticalAlignment="Center"/>
                                                <TextBox Name="PaperCustomW" Width="80"
                                                         Height="26" FontSize="11"
                                                         Text="794" Margin="4,0,8,0"
                                                         TextChanged="PaperCustomW_Changed"/>
                                                <TextBlock Text="H" FontSize="11" Width="14"
                                                           Foreground="{DynamicResource SecondaryText}"
                                                           VerticalAlignment="Center"/>
                                                <TextBox Name="PaperCustomH" Width="80"
                                                         Height="26" FontSize="11"
                                                         Text="1123" Margin="4,0,0,0"
                                                         TextChanged="PaperCustomH_Changed"/>
                                            </DockPanel>
                                        </StackPanel>
                                    </Border>

                                </StackPanel>
                            </ScrollViewer>


                        </Grid>
                    </Border>

                </Grid>
            </Grid>

            <!-- ══ CANVAS AREA ═════════════════════════════════════ -->
            <Grid Name="CenterContent" Grid.Column="1" Background="{DynamicResource AppBg}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Canvas header -->
                <Border Name="CenterPanelHeader" Grid.Row="0" Height="38"
                        Background="{DynamicResource Surface2Bg}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,0,0,1" Padding="18,0">
                    <TextBlock Name="CenterPanelTitle" Text="ALPHABET EDIT"
                               FontSize="10" FontWeight="SemiBold"
                               Foreground="{DynamicResource SecondaryText}"
                               VerticalAlignment="Center"/>
                </Border>

                <!-- Note tabs bar -->
                <Border Name="NoteTabBar" Grid.Row="1" Visibility="Collapsed"
                        Background="{DynamicResource Surface2Bg}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,0,0,1" Height="36">
                    <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                  VerticalScrollBarVisibility="Disabled">
                        <StackPanel Name="NoteTabsPanel" Orientation="Horizontal"/>
                    </ScrollViewer>
                </Border>

                <!-- Type mode formatting toolbar -->
                <Border Name="TypeToolbar" Grid.Row="2" Visibility="Collapsed"
                        Background="{DynamicResource Surface2Bg}"
                        BorderBrush="{DynamicResource AppBorderBrush}"
                        BorderThickness="0,0,0,1">
                    <DockPanel Margin="6,4,6,4" LastChildFill="False">

                        <!-- Word / char counter (right) -->
                        <TextBlock Name="TypeStatsLabel" DockPanel.Dock="Right"
                                   VerticalAlignment="Center" Margin="8,0,6,0"
                                   FontSize="11" Foreground="{DynamicResource SecondaryText}"/>

                        <!-- Save status (right) -->
                        <StackPanel Name="SaveStatePanel" DockPanel.Dock="Right" Orientation="Horizontal"
                                    VerticalAlignment="Center" Margin="8,0,2,0" Visibility="Collapsed">
                            <Ellipse Name="SaveStateDot" Width="7" Height="7" Margin="0,0,5,0"
                                     VerticalAlignment="Center" Fill="{DynamicResource SuccessBrush}"/>
                            <TextBlock Name="SaveStateLabel" Text="Saved" FontSize="11"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource SecondaryText}"/>
                        </StackPanel>

                        <!-- Backlinks -->
                        <Grid DockPanel.Dock="Right" VerticalAlignment="Center" Margin="0,0,4,0">
                            <Button Name="BacklinksBtn" Click="BacklinksBtn_Click"
                                    Height="26" Padding="8,0" ToolTip="Notes linking here (backlinks)">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#x1F517;" FontSize="11" Margin="0,0,5,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Name="BacklinksCountText" Text="0" FontSize="11"
                                               VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Popup Name="BacklinksPopup" PlacementTarget="{Binding ElementName=BacklinksBtn}"
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True"
                                   VerticalOffset="4">
                                <Border Background="{DynamicResource CardBg}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1" CornerRadius="10" Padding="6" MinWidth="220">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000" BlurRadius="24" ShadowDepth="5" Opacity="0.5"/>
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="LINKED FROM" FontSize="11" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryText}" Margin="8,4,8,6"/>
                                        <StackPanel Name="BacklinksPanel"/>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>

                        <!-- ‹ All notes (only when note active) -->
                        <Button Name="NotesBackBtn" DockPanel.Dock="Left"
                                Visibility="Collapsed"
                                Click="NotesBack_Click"
                                Height="26" Padding="8,0" Margin="0,0,2,0"
                                Background="Transparent" BorderThickness="0"
                                ToolTip="Save and back to notes">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#x2039;" FontSize="15"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center" Margin="0,-1,4,0"/>
                                <TextBlock Text="All notes" FontSize="11"
                                           Foreground="{DynamicResource AccentBrush}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Border Name="NotesBackSep" DockPanel.Dock="Left"
                                Visibility="Collapsed"
                                Width="1" Margin="4,3,8,3"
                                Background="{DynamicResource AppBorderBrush}"/>

                        <!-- ── Left: formatting controls ─────────────── -->
                        <!-- Format: Bold Italic Underline Strike -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,4,0">
                            <Button Name="TbBoldBtn" Content="B" ToolTip="Bold (Ctrl+B)"
                                    Click="TbBold_Click" FontWeight="Bold"
                                    Width="28" Height="26" Margin="1,1" FontSize="13"/>
                            <Button Name="TbItalicBtn" Content="I" ToolTip="Italic (Ctrl+I)"
                                    Click="TbItalic_Click" FontStyle="Italic"
                                    Width="28" Height="26" Margin="1,1" FontSize="13"/>
                            <Button Name="TbUnderlineBtn" ToolTip="Underline (Ctrl+U)"
                                    Click="TbUnderline_Click" AutomationProperties.Name="Underline"
                                    Width="28" Height="26" Margin="1,1">
                                <TextBlock TextDecorations="Underline" Text="U" FontSize="13"/>
                            </Button>
                            <Button Name="TbStrikeBtn" ToolTip="Strikethrough"
                                    Click="TbStrike_Click" AutomationProperties.Name="Strikethrough"
                                    Width="28" Height="26" Margin="1,1">
                                <TextBlock TextDecorations="Strikethrough" Text="S" FontSize="13"/>
                            </Button>
                        </StackPanel>

                        <Border DockPanel.Dock="Left" Width="1" Margin="4,3,8,3"
                                Background="{DynamicResource AppBorderBrush}"/>

                        <!-- Lists -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,4,0">
                            <Button ToolTip="Heading (cycle H1/H2/H3)" Click="CycleHeading_Click"
                                    AutomationProperties.Name="Cycle heading level"
                                    Width="28" Height="26" Margin="1,1">
                                <TextBlock Text="H" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>
                            </Button>
                            <Button ToolTip="Bullet list" Click="InsertBullet_Click"
                                    AutomationProperties.Name="Bullet list"
                                    Width="28" Height="26" Margin="1,1">
                                <TextBlock Text="&#x2022;" FontSize="16" VerticalAlignment="Center"/>
                            </Button>
                            <Button ToolTip="Checklist item" Click="InsertCheckbox_Click"
                                    AutomationProperties.Name="Checklist item"
                                    Width="28" Height="26" Margin="1,1">
                                <TextBlock Text="&#x2611;" FontSize="14" VerticalAlignment="Center"/>
                            </Button>
                        </StackPanel>

                        <Border DockPanel.Dock="Left" Width="1" Margin="4,3,8,3"
                                Background="{DynamicResource AppBorderBrush}"/>

                        <!-- Alignment -->
                        <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" Margin="0,0,4,0">
                            <Button Name="TbAlignLBtn" ToolTip="Align Left" AutomationProperties.Name="Align left"
                                    Click="AlignLeft_Click" Width="30" Height="26" Margin="1,1">
                                <StackPanel Width="17" Height="13" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Height="2" Margin="0,0,0,2" CornerRadius="1" HorizontalAlignment="Stretch" Background="{DynamicResource PrimaryText}"/>
                                    <Border Height="2" Width="11" Margin="0,0,0,2" CornerRadius="1" HorizontalAlignment="Left" Background="{DynamicResource PrimaryText}"/>
                                    <Border Height="2" Width="14" CornerRadius="1" HorizontalAlignment="Left" Background="{DynamicResource PrimaryText}"/>
                                </StackPanel>
                            </Button>
                            <Button Name="TbAlignCBtn" ToolTip="Align Center" AutomationProperties.Name="Align center"
                                    Click="AlignCenter_Click" Width="30" Height="26" Margin="1,1">
                                <StackPanel Width="17" Height="13" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Height="2" Margin="0,0,0,2" CornerRadius="1" HorizontalAlignment="Stretch" Background="{DynamicResource PrimaryText}"/>
                                    <Border Height="2" Width="11" Margin="0,0,0,2" CornerRadius="1" HorizontalAlignment="Center" Background="{DynamicResource PrimaryText}"/>
                                    <Border Height="2" Width="14" CornerRadius="1" HorizontalAlignment="Center" Background="{DynamicResource PrimaryText}"/>
                                </StackPanel>
                            </Button>
                            <Button Name="TbAlignRBtn" ToolTip="Align Right" AutomationProperties.Name="Align right"
                                    Click="AlignRight_Click" Width="30" Height="26" Margin="1,1">
                                <StackPanel Width="17" Height="13" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Height="2" Margin="0,0,0,2" CornerRadius="1" HorizontalAlignment="Stretch" Background="{DynamicResource PrimaryText}"/>
                                    <Border Height="2" Width="11" Margin="0,0,0,2" CornerRadius="1" HorizontalAlignment="Right" Background="{DynamicResource PrimaryText}"/>
                                    <Border Height="2" Width="14" CornerRadius="1" HorizontalAlignment="Right" Background="{DynamicResource PrimaryText}"/>
                                </StackPanel>
                            </Button>
                            <Button Name="TbAlignJBtn" ToolTip="Justify" AutomationProperties.Name="Justify"
                                    Click="AlignJustify_Click" Width="30" Height="26" Margin="1,1">
                                <StackPanel Width="17" Height="13" VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <Border Height="2" Margin="0,0,0,2" CornerRadius="1" HorizontalAlignment="Stretch" Background="{DynamicResource PrimaryText}"/>
                                    <Border Height="2" Margin="0,0,0,2" CornerRadius="1" HorizontalAlignment="Stretch" Background="{DynamicResource PrimaryText}"/>
                                    <Border Height="2" CornerRadius="1" HorizontalAlignment="Stretch" Background="{DynamicResource PrimaryText}"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <Border DockPanel.Dock="Left" Width="1" Margin="4,3,8,3"
                                Background="{DynamicResource AppBorderBrush}"/>

                        <!-- Color picker -->
                        <Button DockPanel.Dock="Left" Name="TbColorBtn" ToolTip="Text Color"
                                AutomationProperties.Name="Text colour"
                                Click="TypeColorPickerBtn_Click" Width="36" Height="26" Margin="1,1">
                            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
                                <TextBlock Text="A" FontSize="13" FontWeight="SemiBold"
                                           HorizontalAlignment="Center" Margin="0,-1,0,0"/>
                                <Border Name="TbColorBar" Height="3" CornerRadius="1" Margin="4,1,4,0"
                                        Background="{Binding Background, ElementName=TypeColorSwatch}"/>
                            </StackPanel>
                        </Button>

                        <Border DockPanel.Dock="Left" Width="1" Margin="4,3,8,3"
                                Background="{DynamicResource AppBorderBrush}"/>

                        <!-- Font picker -->
                        <ComboBox Name="TypeFontCombo" DockPanel.Dock="Left"
                                  Height="26" Width="150" FontSize="11" Margin="1,1"
                                  SelectionChanged="TypeFontCombo_SelectionChanged"
                                  ToolTip="Font"/>

                        <!-- ── Right: Voice Input ─────────────────────── -->
                        <Border DockPanel.Dock="Right" Width="1" Margin="8,3,4,3"
                                Background="{DynamicResource AppBorderBrush}"/>
                        <ComboBox Name="SttLangCombo" DockPanel.Dock="Right"
                                  Height="26" Width="52" FontSize="10" Margin="2,1"
                                  SelectionChanged="SttLang_Changed" ToolTip="Language">
                            <ComboBoxItem Content="en" IsSelected="True"/>
                            <ComboBoxItem Content="pl"/>
                            <ComboBoxItem Content="de"/>
                            <ComboBoxItem Content="fr"/>
                            <ComboBoxItem Content="es"/>
                            <ComboBoxItem Content="it"/>
                            <ComboBoxItem Content="auto"/>
                        </ComboBox>
                        <ComboBox Name="SttDurationCombo" DockPanel.Dock="Right"
                                  Height="26" Width="50" FontSize="10" Margin="2,1"
                                  SelectionChanged="SttDuration_Changed"
                                  ToolTip="Chunk length — how often speech is transcribed while you talk (lower = snappier, choppier)">
                            <ComboBoxItem Content="3s"/>
                            <ComboBoxItem Content="5s" IsSelected="True"/>
                            <ComboBoxItem Content="10s"/>
                            <ComboBoxItem Content="15s"/>
                            <ComboBoxItem Content="30s"/>
                        </ComboBox>
                        <Button Name="SpeechBtn" DockPanel.Dock="Right"
                                Height="26" Padding="8,0" Margin="2,1"
                                BorderThickness="0"
                                Background="{DynamicResource NavActiveBg}"
                                Click="SpeechBtn_Click"
                                ToolTip="Voice input — click to start, click again to stop (Ctrl+M)">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Name="SpeechBtnIcon" Text="🎤" FontSize="12"
                                           VerticalAlignment="Center" Margin="0,0,5,0"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Voice" FontSize="11" FontWeight="SemiBold"/>
                                    <TextBlock Name="SttStatusLabel" Text="push to talk"
                                               FontSize="10" Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </DockPanel>
                </Border>

                <Grid Grid.Row="3">
                    <ScrollViewer Name="AlphabetScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  PreviewMouseWheel="AlphabetCanvas_PreviewMouseWheel"
                                  Background="{DynamicResource CanvasBg}">
                        <Grid Name="AlphabetGridHost" Background="{DynamicResource CanvasBg}">
                            <skia:SKElement Name="AlphabetEditCanvas"
                                            PaintSurface="AlphabetEditCanvas_PaintSurface"
                                            IsHitTestVisible="False"/>
                            <Canvas Name="AlphabetInputCanvas" Background="Transparent"
                                    Focusable="False" KeyboardNavigation.IsTabStop="False"
                                    Stylus.IsPressAndHoldEnabled="False"
                                    MouseLeftButtonDown="Alphabet_MouseDown"
                                    MouseMove="Alphabet_MouseMove"
                                    MouseLeftButtonUp="Alphabet_MouseUp"
                                    MouseRightButtonDown="Alphabet_MouseRightDown"
                                    StylusDown="Alphabet_StylusDown"
                                    StylusMove="Alphabet_StylusMove"
                                    StylusUp="Alphabet_StylusUp"/>
                        </Grid>
                    </ScrollViewer>
                    <ScrollViewer Name="TypeScrollViewer" Visibility="Collapsed"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  MouseDown="TypeScrollViewer_MouseDown"
                                  MouseMove="TypeScrollViewer_MouseMove"
                                  MouseUp="TypeScrollViewer_MouseUp"
                                  Background="{DynamicResource CanvasBg}">
                        <Grid Name="TypeCanvasHost" Background="{DynamicResource CanvasBg}"
                              VerticalAlignment="Top">
                            <skia:SKElement Name="TypeSkiaCanvas"
                                            PaintSurface="TypeSkia_PaintSurface"
                                            IsHitTestVisible="False"/>
                            <Canvas Name="DisplayCanvas" Background="Transparent"
                                    Focusable="False" KeyboardNavigation.IsTabStop="False"
                                    MouseLeftButtonDown="TypeCanvas_MouseDown"
                                    MouseMove="TypeCanvas_MouseMove"
                                    MouseLeftButtonUp="TypeCanvas_MouseUp"
                                    MouseRightButtonUp="TypeCanvas_RightClick"
                                    AllowDrop="True"
                                    DragOver="TypeCanvas_DragOver"
                                    Drop="TypeCanvas_Drop"
                                    Cursor="IBeam"/>
                        </Grid>
                    </ScrollViewer>

                    <!-- Font-incomplete banner (Type mode, drawn font with missing glyphs) -->
                    <Border Name="FontIncompleteBanner" Visibility="Collapsed"
                            VerticalAlignment="Top" HorizontalAlignment="Stretch"
                            Background="{DynamicResource NavActiveBg}"
                            BorderBrush="{DynamicResource AccentBrush}"
                            BorderThickness="0,0,0,1" Padding="18,9" Panel.ZIndex="40">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Click="FontIncompleteDismiss_Click"
                                    Width="24" Height="24" Padding="0" Margin="10,0,0,0"
                                    Background="Transparent" BorderThickness="0" ToolTip="Dismiss">
                                <TextBlock Text="&#x2715;" FontSize="10"
                                           Foreground="{DynamicResource SecondaryText}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                            <Button DockPanel.Dock="Right" Click="FontIncompleteFinish_Click"
                                    Height="28" Padding="12,0"
                                    Background="{DynamicResource AccentBrush}" Foreground="White"
                                    BorderThickness="0" ToolTip="Draw the missing characters">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="&#x270F;" FontSize="12" Margin="0,0,6,0"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="Finish in Edit" FontSize="11.5" FontWeight="SemiBold"
                                               Foreground="White" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x270D;" FontSize="14" Margin="0,0,10,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Name="FontIncompleteText" FontSize="12.5"
                                           Foreground="{DynamicResource PrimaryText}"
                                           VerticalAlignment="Center" TextWrapping="Wrap"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Find-in-note bar (floats over the paper) -->
                    <Border Name="FindBar" Visibility="Collapsed"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,12,18,0" Padding="8,6"
                            Background="{DynamicResource PanelBg}"
                            BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="1" CornerRadius="8" Panel.ZIndex="50">
                        <Border.Effect>
                            <DropShadowEffect Color="#000" BlurRadius="18" ShadowDepth="4" Opacity="0.45"/>
                        </Border.Effect>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#x1F50D;" FontSize="12" Opacity="0.6"
                                       VerticalAlignment="Center" Margin="2,0,8,0"/>
                            <Grid Width="190" Height="28" VerticalAlignment="Center">
                                <TextBox Name="FindBox" Panel.ZIndex="0"
                                         Background="#2C2C2C"
                                         Foreground="#FFFFFF" CaretBrush="#FFFFFF"
                                         BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                                         VerticalContentAlignment="Center" FontSize="12.5" Padding="8,0"
                                         AutomationProperties.Name="Find in note"
                                         TextChanged="FindBox_TextChanged" KeyDown="FindBox_KeyDown"/>
                                <TextBlock Name="FindPlaceholder" Text="Find in note…"
                                           FontSize="12.5" Opacity="0.5" Foreground="#AAAAAA"
                                           VerticalAlignment="Center" Margin="9,0,0,0"
                                           IsHitTestVisible="False" Panel.ZIndex="1"/>
                            </Grid>
                            <TextBlock Name="FindCountText" Text="" FontSize="11"
                                       Foreground="{DynamicResource SecondaryText}"
                                       VerticalAlignment="Center" MinWidth="34"
                                       TextAlignment="Center" Margin="8,0,6,0"/>
                            <Button Click="FindPrev_Click" Width="30" Height="28" ToolTip="Previous (Shift+Enter)"
                                    AutomationProperties.Name="Find previous">
                                <TextBlock Text="&#x2039;" FontFamily="Segoe UI" FontSize="17" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryText}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                            </Button>
                            <Button Click="FindNext_Click" Width="30" Height="28" Margin="3,0,0,0" ToolTip="Next (Enter)"
                                    AutomationProperties.Name="Find next">
                                <TextBlock Text="&#x203A;" FontFamily="Segoe UI" FontSize="17" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryText}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center" Margin="0,-2,0,0"/>
                            </Button>
                            <Button Click="FindClose_Click" Width="30" Height="28" Margin="3,0,0,0" ToolTip="Close (Esc)"
                                    AutomationProperties.Name="Close find bar">
                                <TextBlock Text="&#x2715;" FontFamily="Segoe UI" FontSize="11"
                                           Foreground="{DynamicResource PrimaryText}"
                                           VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- ── NOTES PANEL ──────────────────────────────── -->
                    <Grid Name="NotesPanel" Visibility="Collapsed" Background="{DynamicResource AppBg}">

                        <!-- ══ LIBRARY VIEW ══════════════════════════ -->
                        <Grid Name="NotesLibraryView">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>

                            <!-- Header -->
                            <StackPanel Grid.Row="0" Margin="32,28,32,14">
                                <DockPanel>
                                    <ComboBox DockPanel.Dock="Right" Name="SortCombo"
                                              Width="150" Height="30" FontSize="11"
                                              VerticalAlignment="Center" Margin="0,0,8,0"
                                              ToolTip="Sort order"
                                              SelectionChanged="SortCombo_Changed">
                                        <ComboBoxItem Content="Manual order" Tag="manual" IsSelected="True"/>
                                        <ComboBoxItem Content="Name (A–Z)" Tag="name"/>
                                        <ComboBoxItem Content="Date created" Tag="created"/>
                                        <ComboBoxItem Content="Date modified" Tag="modified"/>
                                    </ComboBox>
                                    <TextBlock Name="NotesViewTitle" Text="Home"
                                               FontSize="20" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryText}"
                                               VerticalAlignment="Center"/>
                                </DockPanel>

                                <!-- Search -->
                                <Border Background="{DynamicResource Surface2Bg}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1" CornerRadius="8"
                                        Margin="0,14,0,0" Padding="10,0">
                                    <DockPanel>
                                        <TextBlock DockPanel.Dock="Left" Text="&#x1F50D;"
                                                   FontSize="12" Opacity="0.5"
                                                   VerticalAlignment="Center" Margin="0,0,8,0"/>
                                        <Button DockPanel.Dock="Right" Name="SearchClearBtn"
                                                Width="22" Height="22" Padding="0"
                                                Background="Transparent" BorderThickness="0"
                                                Visibility="Collapsed"
                                                Click="SearchClear_Click" ToolTip="Clear">
                                            <TextBlock Text="&#x2715;" FontSize="10"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Button>
                                        <Grid>
                                            <TextBlock Name="SearchPlaceholder" Text="Search notes and #tags…"
                                                       FontSize="12.5" Opacity="0.45"
                                                       Foreground="{DynamicResource SecondaryText}"
                                                       VerticalAlignment="Center" IsHitTestVisible="False"/>
                                            <TextBox Name="NotesSearchBox" Height="36"
                                                     Background="Transparent" BorderThickness="0"
                                                     VerticalContentAlignment="Center"
                                                     FontSize="12.5"
                                                     AutomationProperties.Name="Search notes and tags"
                                                     TextChanged="NotesSearch_TextChanged"/>
                                        </Grid>
                                    </DockPanel>
                                </Border>

                                <!-- Tag filter strip -->
                                <WrapPanel Name="TagFilterPanel" Margin="0,10,0,0"/>
                            </StackPanel>

                            <!-- Notebook content -->
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="0,0,2,0">
                                <StackPanel Margin="32,0,32,32">

                                    <!-- Recently opened (Home only) -->
                                    <StackPanel Name="RecentSection" Visibility="Collapsed" Margin="0,0,0,18">
                                        <TextBlock Text="RECENTLY OPENED" Style="{StaticResource SectionLabel}"/>
                                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                                      VerticalScrollBarVisibility="Disabled">
                                            <StackPanel Name="RecentPanel" Orientation="Horizontal"/>
                                        </ScrollViewer>
                                    </StackPanel>

                                    <!-- Favorites (Home only) -->
                                    <StackPanel Name="FavoritesSection" Visibility="Collapsed" Margin="0,0,0,18">
                                        <TextBlock Text="FAVORITES" Style="{StaticResource SectionLabel}"/>
                                        <WrapPanel Name="FavoritesPanel" Orientation="Horizontal"/>
                                    </StackPanel>

                                    <!-- All / folder notes -->
                                    <TextBlock Name="AllNotesLabel" Text="ALL NOTES"
                                               Style="{StaticResource SectionLabel}"/>
                                    <WrapPanel Name="NotesGridPanel" Orientation="Horizontal"/>
                                </StackPanel>
                            </ScrollViewer>

                            <!-- Empty state -->
                            <Border Name="NotesEmptyState" Grid.Row="1" Visibility="Collapsed">
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center"
                                            MaxWidth="320">
                                    <Border Width="84" Height="84" CornerRadius="20"
                                            Background="{DynamicResource Surface2Bg}"
                                            BorderBrush="{DynamicResource AppBorderBrush}"
                                            BorderThickness="1"
                                            HorizontalAlignment="Center" Margin="0,0,0,18">
                                        <TextBlock Name="EmptyStateIcon" Text="&#x1F4D3;" FontSize="40"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Opacity="0.85"/>
                                    </Border>
                                    <TextBlock Name="EmptyStateTitle" Text="No notes yet"
                                               FontSize="16" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryText}"
                                               HorizontalAlignment="Center" Margin="0,0,0,7"/>
                                    <TextBlock Name="EmptyStateHint" Text="Create your first notebook to start writing by hand."
                                               FontSize="12.5" TextWrapping="Wrap"
                                               LineHeight="18"
                                               TextAlignment="Center"
                                               Foreground="{DynamicResource SecondaryText}"
                                               HorizontalAlignment="Center" Margin="0,0,0,20"/>
                                    <Button Name="EmptyStateBtn" Click="EmptyStateBtn_Click"
                                            HorizontalAlignment="Center"
                                            Height="38" Padding="20,0"
                                            Background="{DynamicResource AccentBrush}"
                                            BorderThickness="0" Foreground="White">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Name="EmptyStateBtnIcon" Text="+" FontSize="17"
                                                       FontWeight="Light" Foreground="White"
                                                       VerticalAlignment="Center" Margin="0,-2,7,0"/>
                                            <TextBlock Name="EmptyStateBtnText" Text="New note" FontSize="13"
                                                       FontWeight="SemiBold" Foreground="White"
                                                       VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </Grid>

                    </Grid>
                </Grid>
            </Grid>

        </Grid>

        <!-- Off-screen state holders: the note title + save-status sink are kept
             in memory but have no on-screen editor of their own. -->
        <Grid Visibility="Collapsed">
            <TextBox Name="NoteTitleBox" TextChanged="NoteTitle_Changed"/>
            <TextBlock Name="NotesSavedLabel"/>
        </Grid>

        <!-- Save-before-close overlay -->
        <Grid Name="SaveCloseOverlay" Grid.RowSpan="2" Visibility="Collapsed" KeyboardNavigation.TabNavigation="Cycle"
              Background="#88000000" Panel.ZIndex="100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="360"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="24,22,24,18">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55"
                                      BlurRadius="32" ShadowDepth="8" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Save changes?" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}"
                               Margin="0,0,0,10"/>
                    <TextBlock Name="SaveCloseMsg"
                               TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="Don't save" Click="SaveCloseDontSave_Click"
                                Height="32" Padding="16,0" Margin="0,0,8,0"/>
                        <Button Content="Cancel" Click="SaveCloseCancel_Click"
                                Height="32" Padding="16,0" Margin="0,0,8,0"/>
                        <Button Content="Save" Click="SaveCloseSave_Click"
                                Height="32" Padding="20,0"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Delete note confirmation overlay -->
        <Grid Name="DeleteConfirmOverlay" Grid.RowSpan="2" Visibility="Collapsed" KeyboardNavigation.TabNavigation="Cycle"
              Background="#88000000" Panel.ZIndex="100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="340"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="24,22,24,18">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55"
                                      BlurRadius="32" ShadowDepth="8" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Delete note?" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}"
                               Margin="0,0,0,10"/>
                    <TextBlock Name="DeleteConfirmMsg"
                               TextWrapping="Wrap" FontSize="12"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,0,0,24"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Name="DeleteCancelBtn" Content="Cancel"
                                Click="DeleteCancel_Click"
                                Height="32" Padding="20,0" Margin="0,0,10,0"/>
                        <Button Name="DeleteConfirmBtn" Content="Delete"
                                Click="DeleteConfirm_Click"
                                Height="32" Padding="20,0"
                                Background="{DynamicResource DangerBrush}"
                                Foreground="White"
                                BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Rename note overlay -->
        <Grid Name="RenameOverlay" Grid.RowSpan="2" Visibility="Collapsed" KeyboardNavigation.TabNavigation="Cycle"
              Background="#88000000" Panel.ZIndex="100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="320"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="24,22,24,18">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55"
                                      BlurRadius="32" ShadowDepth="8" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Rename note" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,14"/>
                    <TextBox Name="RenameBox" FontSize="13" Padding="10,8"
                             KeyDown="RenameBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="Cancel" Click="RenameCancel_Click"
                                Height="32" Padding="16,0" Margin="0,0,8,0"/>
                        <Button Content="Rename" Click="RenameConfirm_Click"
                                Height="32" Padding="20,0"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Edit tags overlay -->
        <Grid Name="TagsOverlay" Grid.RowSpan="2" Visibility="Collapsed" KeyboardNavigation.TabNavigation="Cycle"
              Background="#88000000" Panel.ZIndex="100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="340"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="24,22,24,18">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55"
                                      BlurRadius="32" ShadowDepth="8" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Edit tags" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,6"/>
                    <TextBlock Text="Separate tags with commas"
                               FontSize="11" Foreground="{DynamicResource SecondaryText}"
                               Margin="0,0,0,14"/>
                    <TextBox Name="TagsBox" FontSize="13" Padding="10,8"
                             KeyDown="TagsBox_KeyDown"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                        <Button Content="Cancel" Click="TagsCancel_Click"
                                Height="32" Padding="16,0" Margin="0,0,8,0"/>
                        <Button Content="Save" Click="TagsConfirm_Click"
                                Height="32" Padding="20,0"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- New note: template picker -->
        <Grid Name="NewNoteOverlay" Grid.RowSpan="2" Visibility="Collapsed" KeyboardNavigation.TabNavigation="Cycle"
              Background="#88000000" Panel.ZIndex="100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="24,22,24,18">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55"
                                      BlurRadius="32" ShadowDepth="8" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="New note" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}" Margin="2,0,0,4"/>
                    <TextBlock Text="Start blank or from a template"
                               FontSize="11.5" Foreground="{DynamicResource SecondaryText}"
                               Margin="2,0,0,16"/>
                    <WrapPanel Name="NewNotePanel" MaxWidth="420"/>
                    <Button Content="Cancel" Click="NewNoteCancel_Click"
                            HorizontalAlignment="Right" Height="32" Padding="16,0" Margin="0,14,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Font export range overlay -->
        <Grid Name="FontRangeOverlay" Grid.RowSpan="2" Visibility="Collapsed" KeyboardNavigation.TabNavigation="Cycle"
              Background="#88000000" Panel.ZIndex="100">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="340"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="10"
                    Padding="24,22,24,18">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55"
                                      BlurRadius="32" ShadowDepth="8" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Text="Export font" FontSize="15" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,6"/>
                    <TextBlock Text="Choose which characters to include. Only drawn ones are exported."
                               FontSize="11" TextWrapping="Wrap"
                               Foreground="{DynamicResource SecondaryText}" Margin="0,0,0,16"/>
                    <CheckBox Name="RangeUpper" Content="Uppercase  A–Z" IsChecked="True"
                              Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8"/>
                    <CheckBox Name="RangeLower" Content="Lowercase  a–z" IsChecked="True"
                              Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8"/>
                    <CheckBox Name="RangeDigits" Content="Digits  0–9" IsChecked="True"
                              Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8"/>
                    <CheckBox Name="RangePunct" Content="Punctuation  . , ! ? …" IsChecked="True"
                              Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,8"/>
                    <CheckBox Name="RangePolish" Content="Polish  ą ę ó ś …" IsChecked="False"
                              Foreground="{DynamicResource PrimaryText}" Margin="0,0,0,0"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                        <Button Content="Cancel" Click="FontRangeCancel_Click"
                                Height="32" Padding="16,0" Margin="0,0,8,0"/>
                        <Button Content="Export .ttf" Click="FontRangeExport_Click"
                                Height="32" Padding="18,0"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White" BorderThickness="0"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Toast notification host (bottom-right, above everything) -->
        <StackPanel Name="ToastHost" Grid.RowSpan="2"
                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="0,0,20,20" Panel.ZIndex="200"
                    IsHitTestVisible="True"/>

        <!-- Busy overlay for long batch ops (scan import, model load) -->
        <Grid Name="BusyOverlay" Grid.RowSpan="2" Visibility="Collapsed"
              Background="#88000000" Panel.ZIndex="260">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="28,22">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.55"
                                      BlurRadius="32" ShadowDepth="8" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <TextBlock Name="BusyLabel" Text="Working…" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryText}"
                               HorizontalAlignment="Center" Margin="0,0,0,14"/>
                    <ProgressBar IsIndeterminate="True" Style="{x:Null}"
                                 Height="5" Width="240"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Background="{DynamicResource Surface2Bg}"
                                 BorderThickness="0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Command palette (Ctrl+K) -->
        <Grid Name="CommandPaletteOverlay" Grid.RowSpan="2" Visibility="Collapsed" KeyboardNavigation.TabNavigation="Cycle"
              Background="#88000000" Panel.ZIndex="280"
              MouseLeftButtonDown="CommandPalette_BackdropClick">
            <Border Width="540" VerticalAlignment="Top" Margin="0,110,0,0"
                    HorizontalAlignment="Center"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="12"
                    MouseLeftButtonDown="CommandPalette_CardClick">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.6"
                                      BlurRadius="40" ShadowDepth="10" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <!-- search -->
                    <Border BorderBrush="{DynamicResource AppBorderBrush}"
                            BorderThickness="0,0,0,1" Padding="14,12">
                        <DockPanel>
                            <TextBlock DockPanel.Dock="Left" Text="&#x1F50D;" FontSize="13"
                                       Opacity="0.5" VerticalAlignment="Center" Margin="0,0,10,0"/>
                            <TextBox Name="CommandSearchBox" Background="Transparent"
                                     BorderThickness="0" FontSize="14"
                                     VerticalContentAlignment="Center"
                                     AutomationProperties.Name="Command palette search"
                                     TextChanged="CommandSearch_TextChanged"/>
                        </DockPanel>
                    </Border>
                    <!-- results -->
                    <ScrollViewer MaxHeight="360" VerticalScrollBarVisibility="Auto">
                        <StackPanel Name="CommandListPanel" Margin="6"/>
                    </ScrollViewer>
                </StackPanel>
            </Border>
        </Grid>

        <!-- Keyboard shortcuts overlay -->
        <Grid Name="ShortcutsOverlay" Grid.RowSpan="2" Visibility="Collapsed" KeyboardNavigation.TabNavigation="Cycle"
              Background="#88000000" Panel.ZIndex="290"
              MouseLeftButtonDown="ShortcutsBackdrop_Click">
            <Border Width="440" MaxHeight="600" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="12" Padding="24,20,24,18"
                    MouseLeftButtonDown="ShortcutsCard_Click">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.6"
                                      BlurRadius="40" ShadowDepth="10" Direction="270"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,4">
                        <Button Name="ShortcutsCloseBtn" DockPanel.Dock="Right" Click="ShortcutsClose_Click"
                                Width="26" Height="26" Padding="0"
                                Background="Transparent" BorderThickness="0"
                                AutomationProperties.Name="Close"
                                ToolTip="Close (Esc)">
                            <TextBlock Text="&#x2715;" FontSize="11"
                                       Foreground="{DynamicResource SecondaryText}"
                                       VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </Button>
                        <TextBlock Name="ShortcutsTitle" Text="Keyboard shortcuts"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryText}"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <StackPanel Name="ShortcutsPanel"/>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>

        <!-- Onboarding overlay (first run) -->
        <Grid Name="OnboardingOverlay" Grid.RowSpan="2" Visibility="Collapsed" KeyboardNavigation.TabNavigation="Cycle"
              Background="#B0000000" Panel.ZIndex="300">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="460"
                    Background="{DynamicResource PanelBg}"
                    BorderBrush="{DynamicResource AppBorderBrush}"
                    BorderThickness="1" CornerRadius="14"
                    Padding="34,30,34,24">
                <Border.Effect>
                    <DropShadowEffect Color="#000000" Opacity="0.6"
                                      BlurRadius="40" ShadowDepth="10" Direction="270"/>
                </Border.Effect>
                <StackPanel>
                    <Border Width="72" Height="72" CornerRadius="18"
                            Background="{DynamicResource Surface2Bg}"
                            BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"
                            HorizontalAlignment="Center" Margin="0,0,0,18">
                        <TextBlock Name="ObIcon" Text="&#x270D;" FontSize="34"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Name="ObTitle" Text="Welcome to nottwrite"
                               FontSize="19" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryText}"
                               TextAlignment="Center" Margin="0,0,0,10"/>
                    <TextBlock Name="ObBody"
                               FontSize="13" LineHeight="20" TextWrapping="Wrap"
                               TextAlignment="Center"
                               Foreground="{DynamicResource SecondaryText}"
                               Margin="0,0,0,22"/>

                    <!-- Intent chooser (shown on the "what do you want to do?" step) -->
                    <StackPanel Name="ObIntentPanel" Visibility="Collapsed" Margin="0,0,0,14">
                        <Button Click="Onboarding_PickIntent" Tag="notes"
                                Height="58" Margin="0,0,0,8"
                                HorizontalContentAlignment="Left" Padding="14,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x1F4D3;" FontSize="22" Margin="0,0,14,0"
                                           VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Write by hand" FontSize="13.5" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBlock Text="Take notes and pages in your own handwriting"
                                               FontSize="11" Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                        <Button Click="Onboarding_PickIntent" Tag="edit"
                                Height="58"
                                HorizontalContentAlignment="Left" Padding="14,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock Text="&#x270F;" FontSize="22" Margin="0,0,14,0"
                                           VerticalAlignment="Center"/>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="Make a font" FontSize="13.5" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryText}"/>
                                    <TextBlock Text="Draw your letters once, export an installable .ttf"
                                               FontSize="11" Foreground="{DynamicResource SecondaryText}"/>
                                </StackPanel>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <!-- step dots -->
                    <StackPanel Name="ObDots" Orientation="Horizontal"
                                HorizontalAlignment="Center" Margin="0,0,0,22"/>

                    <DockPanel>
                        <Button Name="ObSkipBtn" DockPanel.Dock="Left" Content="Skip"
                                Click="Onboarding_Skip" Height="34" Padding="14,0"
                                Background="Transparent"
                                BorderBrush="{DynamicResource AppBorderBrush}" BorderThickness="1"/>
                        <Button Name="ObNextBtn" DockPanel.Dock="Right" Content="Next"
                                Click="Onboarding_Next" Height="34" Padding="22,0"
                                HorizontalAlignment="Right"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="White" BorderThickness="0"/>
                    </DockPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>
