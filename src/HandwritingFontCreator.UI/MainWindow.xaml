<Window x:Class="HandwritingFontCreator.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Handwriting Font Creator"
        Height="700"
        Width="1400">

    <Grid>

        <ComboBox Name="TemplateComboBox"
                  Width="140"
                  Height="35"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Margin="10,10,0,0"
                  SelectionChanged="TemplateComboBox_SelectionChanged"/>

        <ComboBox Name="LetterComboBox"
                  Width="80"
                  Height="35"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Top"
                  Margin="160,10,0,0"/>

        <Button Content="Undo"
                Width="80"
                Height="35"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="250,10,0,0"
                Click="UndoButton_Click"/>

        <Button Content="Redo"
                Width="80"
                Height="35"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="340,10,0,0"
                Click="RedoButton_Click"/>

        <Button Content="Clear"
                Width="100"
                Height="35"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="430,10,0,0"
                Click="ClearButton_Click"/>

        <Button Content="Save Letter"
                Width="120"
                Height="35"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="540,10,0,0"
                Click="SaveButton_Click"/>

        <Button Content="Load Letter"
                Width="120"
                Height="35"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="670,10,0,0"
                Click="LoadButton_Click"/>

        <TextBox Name="GenerateTextBox"
                 Width="200"
                 Height="35"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Top"
                 Margin="800,10,0,0"
                 Text="ABC"/>

        <Button Content="Generate"
                Width="120"
                Height="35"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="1010,10,0,0"
                Click="GenerateButton_Click"/>

        <Button Content="Preview Alphabet"
                Width="140"
                Height="35"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="1140,10,0,0"
                Click="PreviewAlphabetButton_Click"/>

        <ScrollViewer Width="250"
              Margin="0,60,0,0"
              HorizontalAlignment="Left"
              VerticalAlignment="Stretch">

            <UniformGrid Name="CharacterGrid"
                 Columns="6"/>

        </ScrollViewer>

        <StackPanel Orientation="Horizontal"
            Margin="260,60,0,0"
            VerticalAlignment="Top"
            HorizontalAlignment="Left">

            <ProgressBar Name="AlphabetProgressBar"
                 Width="300"
                 Height="25"
                 Maximum="100"/>

            <TextBlock Name="AlphabetProgressText"
               Margin="10,0,0,0"
               VerticalAlignment="Center"
               FontWeight="Bold"/>
        </StackPanel>
        
        <Canvas Name="DrawingCanvas"
                Margin="260,100,0,0"
                Background="White"
                MouseLeftButtonDown="DrawingCanvas_MouseLeftButtonDown"
                MouseMove="DrawingCanvas_MouseMove"
                MouseLeftButtonUp="DrawingCanvas_MouseLeftButtonUp"/>

    </Grid>

</Window>